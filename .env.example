# ─── Site ──────────────────────────────
# Public site base URL for canonical URLs (no trailing slash)
PUBLIC_SITE_URL=https://www.amritaglobaltextiles.com

# ─── Backend API ─────────────────────────────────────────────────────────────
# Internal backend proxy base URL (no trailing slash)
PUBLIC_API_BASE_URL=https://amrita-espo-backend.vercel.app

PUBLIC_ESPO_BASE=https://espo.egport.com/api/v1

# Lead capture key — used by contact, newsletter, and inquiry forms
PUBLIC_LEAD_CAPTURE_KEY=a4624c9bb58b8b755e3d94f1a25fc9be

# Lead capture key — used exclusively by the careers / job application form
PUBLIC_CAREERS_LEAD_CAPTURE_KEY=517205fe58db736ea2438667b84df4d0

# Marketing/tracking fallbacks. Backend SiteSettings values take priority.
PUBLIC_ENABLE_MARKETING_TRACKING=true
PUBLIC_GA_MEASUREMENT_ID=
PUBLIC_GTM_ID=
PUBLIC_CLARITY_ID=
PUBLIC_META_PIXEL_ID=
