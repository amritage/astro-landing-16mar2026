# ─── Site ────────────────────────────────────────────────────────────────────
# Public site base URL for canonical URLs (no trailing slash)
PUBLIC_SITE_URL=https://www.amrita-fashions.com

# ─── Backend API ─────────────────────────────────────────────────────────────
# Internal backend proxy base URL (no trailing slash)
PUBLIC_API_BASE_URL=https://espobackend.vercel.app

# ─── EspoCRM (SERVER-ONLY — no PUBLIC_ prefix, never sent to the browser) ────
# EspoCRM instance base URL (no trailing slash)
ESPO_BASE=https://espo.egport.com/api/v1

# Lead capture key — used by contact, newsletter, and inquiry forms
LEAD_CAPTURE_KEY=a4624c9bb58b8b755e3d94f1a25fc9be

# Lead capture key — used exclusively by the careers / job application form
CAREERS_LEAD_CAPTURE_KEY=517205fe58db736ea2438667b84df4d0

# ─── IMPORTANT ───────────────────────────────────────────────────────────────
# The old PUBLIC_ESPO_BASE / PUBLIC_LEAD_CAPTURE_KEY vars are REMOVED.
# They were visible in the browser bundle. The new server-only vars above
# are only accessible inside Astro API routes (src/pages/api/*.ts).
# Update your Vercel project environment variables accordingly.
