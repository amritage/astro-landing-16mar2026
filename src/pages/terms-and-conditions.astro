---
import BaseLayout from "../layouts/BaseLayout.astro";
import TermsHero from "../components/terms/TermsHero.astro";
import TermsNav from "../components/terms/TermsNav.astro";
import TermsContent from "../components/terms/TermsContent.astro";
import { getTopicPageBySlug } from "../lib/api";

const seo = await getTopicPageBySlug("terms-and-conditions");
---

<BaseLayout
  title={seo?.metaTitle ?? "Wholesale Terms & Legal Policies | Amrita Global Enterprises"}
  description={seo?.description ?? "Terms of service, privacy policy, cookie policy, and wholesale rules for Amrita Global Enterprises — B2B fabric manufacturer and exporter."}
  keywords={seo?.keywords ?? undefined}
  canonical={seo?.canonicalUrl ? `https://${seo.canonicalUrl.replace(/^https?:\/\//, "")}` : undefined}
  ogType={seo?.ogType ?? "website"}
>
  <TermsHero />
  <TermsNav />
  <TermsContent />
</BaseLayout>
