---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FabricListLayout from "../../components/product/FabricListLayout.astro";
import type { FAQItem } from "../../components/product/FabricListLayout.astro";
import { fetchProductsPage } from "../../data/products";
import { getFilterValues, getTopicPageBySlug } from "../../lib/api";

const [{ products: rawProducts, total, totalPages }, filters, seo] = await Promise.all([
  fetchProductsPage(1),
  getFilterValues(),
  getTopicPageBySlug("fabric"),
]);

const products = rawProducts.map((p) => ({
  id: p.id,
  name: p.name,
  category: p.category,
  weight: p.specs.weight,
  width: p.specs.width,
  color: p.hex?.[0] ?? "#041632",
  image: p.image,
  href: p.slug ? `/fabric/${p.slug}` : null,
  filterCategory: p.category,
  filterColor: p.colorNames.join("|"),
  filterStructure: p.structure,
  filterContent: p.content,
  filterGsm: String(p.gsm),
  filterDesign: p.design,
  filterFinish: p.finish.join("|"),
}));

const faqItems: FAQItem[] = [
  {
    question: "What is your Minimum Order Quantity (MOQ)?",
    answer: "Our standard MOQ for stock items is 100 meters per color.",
  },
  {
    question: "Do you provide Oeko-Tex certifications?",
    answer:
      "Yes, selected products can be supplied with relevant testing and certification documents based on buyer requirements.",
  },
];
---

<BaseLayout
  title={seo?.metaTitle ?? "Shop Fabric Catalog | Amrita Global Enterprises"}
  description={seo?.description ?? "Browse our full fabric catalog including cotton twill, woven fabrics, and performance textiles."}
  keywords={seo?.keywords ?? undefined}
  canonical={seo?.canonicalUrl ? `https://${seo.canonicalUrl.replace(/^https?:\/\//, "")}` : undefined}
  ogType={seo?.ogType ?? "product"}
  ogImage={seo?.image1CloudUrlHero ?? seo?.image1CloudUrl ?? undefined}
>
  <div class="bg-white text-slate-900">
    <FabricListLayout
      hero={{
        title: "Browse Our Full Fabric Catalog",
        imageUrl: "https://lh3.googleusercontent.com/aida-public/AB6AXuDXILs7vI9jTFPWWO0ngF8Ui-YT9674spB4lXOMQdOFMu7t5X7RyxOAGKm9YKWwUa4bJjALACc-AydvYav7TOQbv5phLBVC8IRktf5451HZnhTMu9WNYMfXOqEob14cesbhrbM3KPpL4MQ8Try_UlEL_ce65vI2eOFWkh20w8aWmhys0NYqcvPCnr0huz0J7Ub7UX6hobR1a8Nnzh16FVRZvAKH5176oU6Hf2vOc1Ma2YIvbT9sKvweH0wTLaeEHj9OasHKJ9-ClxFx",
        breadcrumbLabel: "Shop",
        breadcrumbHref: "/fabric",
      }}
      intro={{
        heading: "Explore 100% Cotton Twill, Woven Fabrics, and Performance Textiles",
        body: "Precision-engineered for durability and aesthetic excellence. Our curated selection represents the pinnacle of industrial textile manufacturing, sourcing the finest fibers for global brands.",
        calloutTitle: "Technical Assurance",
        calloutBody: "All fabrics undergo 12-point quality inspection including GSM verification, color fastness, and tensile strength testing.",
      }}
      products={products}
      filters={{
        categories: filters.category,
        colors: filters.color,
        structures: filters.structure,
        contents: filters.content,
        designs: filters.design,
        finishes: filters.finish,
      }}
      total={total}
      currentPage={1}
      totalPages={totalPages}
      faqItems={faqItems}
    />
  </div>
</BaseLayout>
