---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPostCTA from "../../components/blog/BlogPostCTA.astro";
import BlogDynamicPostHero from "../../components/blog/BlogDynamicPostHero.astro";
import BlogDynamicPostBody from "../../components/blog/BlogDynamicPostBody.astro";
import { fetchBlogPosts } from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await fetchBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<BaseLayout title={`${post.title} | Amrita Global`} description={post.excerpt}>
  <BlogDynamicPostHero post={post} />
  <BlogDynamicPostBody post={post} />
  <BlogPostCTA />
</BaseLayout>
