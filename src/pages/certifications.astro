---
import BaseLayout from "../layouts/BaseLayout.astro";
import CertificationsHero from "../components/certifications/CertificationsHero.astro";
import CertificationsGrid from "../components/certifications/CertificationsGrid.astro";
import CertificationsDocCTA from "../components/certifications/CertificationsDocCTA.astro";
import CertificationsTrust from "../components/certifications/CertificationsTrust.astro";
import { getCompanyInfo } from "../lib/api";

const company = await getCompanyInfo("AGE");
---

<BaseLayout
  title="Certifications | Amrita Global Enterprises"
  description="ISO 9001, OEKO-TEX, GOTS, and SA 8000 certified. Amrita Global Enterprises upholds the highest international standards for quality, safety, and ethical manufacturing."
>
  <CertificationsHero />
  <CertificationsGrid />
  <CertificationsDocCTA whatsapp={company?.whatsappNumber} phone={company?.phone1} />
  <CertificationsTrust />
</BaseLayout>
