---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQHero from "../components/faq/FAQHero.astro";
import FAQAccordion from "../components/faq/FAQAccordion.astro";
import FAQCTA from "../components/faq/FAQCTA.astro";
import { getWebsiteFAQCategories } from "../lib/api";
import { faqCategories } from "../data/faqs";

const apiCategories = await getWebsiteFAQCategories();
const categories = apiCategories.length > 0 ? apiCategories : faqCategories;
---

<BaseLayout
  title="FAQ | Amrita Global Enterprises"
  description="Expert answers for fabric buyers — sourcing, manufacturing, logistics, pricing, and MOQ questions answered by Amrita Global Enterprises."
>
  <FAQHero />
  <FAQAccordion categories={categories} />
  <FAQCTA />
</BaseLayout>
