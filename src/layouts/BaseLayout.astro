---
import "../styles/global.css";
import Header from "/src/layouts/Header.astro";
import Footer from "/src/layouts/Footer.astro";
import FloatingActions from "../components/common/FloatingActions.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Amrita Fashions",
  description = "B2B fabric manufacturer and exporter.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />
    <style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>
  </head>
  <body class="min-h-screen bg-[var(--color-background)] text-[var(--color-text)]">
    <Header />
    <main class="pt-[94px] md:pt-[102px]">
      <slot />
    </main>
    <Footer />
    <FloatingActions />
  </body>
</html>