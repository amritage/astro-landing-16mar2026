---
import "../styles/global.css";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import FloatingActions from "../components/common/FloatingActions.astro";
import LocalBusinessSchema from "../components/schema/LocalBusinessSchema.astro";
import BreadcrumbSchema from "../components/schema/BreadcrumbSchema.astro";
import ProductInquiryRoot from "../components/product/ProductInquiryRoot.astro";

import { getSiteSettings, getCompanyInfo } from "../lib/api";
import { getSiteOrigin } from "../lib/site-url";

interface Props {
  title?: string | null;
  description?: string | null;
  // Per-page SEO overrides
  canonical?: string | null;
  keywords?: string[];
  ogTitle?: string | null;
  ogDescription?: string | null;
  ogImage?: string | null;
  ogType?: string | null;
  twitterTitle?: string | null;
  twitterDescription?: string | null;
  twitterImage?: string | null;
  schemaMarkup?: object | object[];
  noindex?: boolean;
  breadcrumbs?: { name: string; url?: string }[];
  // LCP image preload
  preloadImage?: string;
  preloadImageSrcset?: string;
  preloadImageSizes?: string;
  // Pass author name from pages that already fetch authors (about, support, blog, etc.)
  // Falls back to company name if not provided — avoids a redundant getAuthors() call in BaseLayout
  authorName?: string;
  // Page-specific WhatsApp pre-filled message for the floating button
  waMessage?: string;
  hideHeader?: boolean;
  hideFooter?: boolean;
  hideFloatingActions?: boolean;
  hideProductInquiryRoot?: boolean;
  mainClass?: string;
}

// Site-wide settings from API (eCatalogue) — fetched before props destructuring so companyName is available as default
const [site, company] = await Promise.all([
  getSiteSettings("eCatalogue"),
  getCompanyInfo("AGE"),
]);

const companyName = company?.legalName ?? company?.name ?? "";

const {
  title = companyName,
  description = "B2B fabric manufacturer and exporter.",
  canonical,
  keywords,
  ogTitle,
  ogDescription,
  ogImage,
  ogType = "website",
  twitterTitle,
  twitterDescription,
  twitterImage,
  schemaMarkup,
  noindex = false,
  breadcrumbs,
  preloadImage,
  preloadImageSrcset,
  preloadImageSizes,
  authorName: authorNameProp,
  waMessage,
  hideHeader = false,
  hideFooter = false,
  hideFloatingActions = false,
  hideProductInquiryRoot = false,
  mainClass = "pt-[94px] md:pt-[102px]",
} = Astro.props;
// Use prop if passed (pages that already fetched authors), otherwise fall back to company name
const authorName = authorNameProp ?? companyName;
const pageTitle = title ?? companyName;
const pageDescription = description ?? "B2B fabric manufacturer and exporter.";

const siteBase = getSiteOrigin();
const pathname = Astro.url.pathname;
const normalizedPath = pathname.replace(/\.html$/, '').replace(/\/index$/, '') || '/';
const rawPath = normalizedPath;
const cleanPath = rawPath === '/' ? '' : rawPath;
const resolvedCanonical = canonical ?? undefined;
const resolvedOgType = ogType ?? "website";
const resolvedOgTitle = ogTitle ?? pageTitle;
const resolvedOgDesc = ogDescription ?? pageDescription;
const resolvedTwitterTitle = twitterTitle ?? resolvedOgTitle;
const resolvedTwitterDesc = twitterDescription ?? resolvedOgDesc;

// Always expose the 512x512 PNG brand icon from public for logo-aware crawlers.
const brandOgLogo = `${siteBase}/icon-512.png`;
const defaultOgImage = brandOgLogo;
const resolvedOgImage = ogImage
  ? (ogImage.startsWith("http") ? ogImage : `${siteBase}${ogImage}`)
  : defaultOgImage;
const resolvedOgImageWidth = ogImage ? 1200 : 512;
const resolvedOgImageHeight = ogImage ? 630 : 512;
const resolvedTwitterImage = twitterImage
  ? (twitterImage.startsWith("http") ? twitterImage : `${siteBase}${twitterImage}`)
  : resolvedOgImage;

// robots: noindex prop overrides, otherwise use API robotsPolicy or default to index, follow
const robotsContent = noindex
  ? "noindex, nofollow"
  : (site?.robotsPolicy ?? "index, follow");

const schemaArray = schemaMarkup
  ? Array.isArray(schemaMarkup) ? schemaMarkup : [schemaMarkup]
  : null;

function cleanTrackingId(value: string | null | undefined): string | null {
  const trimmed = value?.trim();
  if (!trimmed || trimmed === "undefined" || trimmed === "null") return null;
  return trimmed;
}

function envTrackingValue(name: string): string | null {
  return cleanTrackingId(import.meta.env[name] as string | undefined);
}

const marketingTrackingEnabled =
  String(site?.enableMarketingTracking ?? import.meta.env.PUBLIC_ENABLE_MARKETING_TRACKING ?? "true").toLowerCase() !== "false";

const gaMeasurementId = cleanTrackingId(site?.gaMeasurementId) ?? envTrackingValue("PUBLIC_GA_MEASUREMENT_ID");
const gtmId = cleanTrackingId(site?.gtmId) ?? envTrackingValue("PUBLIC_GTM_ID");
const clarityId = cleanTrackingId(site?.clarityId) ?? envTrackingValue("PUBLIC_CLARITY_ID");
const metaPixelId = cleanTrackingId(site?.metaPixelId) ?? envTrackingValue("PUBLIC_META_PIXEL_ID");
const googleAdsConversionId =
  cleanTrackingId(site?.googleAdsConversionId) ?? envTrackingValue("PUBLIC_GOOGLE_ADS_CONVERSION_ID");
const googleAdsLeadConversionLabel =
  cleanTrackingId(site?.googleAdsLeadConversionLabel) ?? envTrackingValue("PUBLIC_GOOGLE_ADS_LEAD_CONVERSION_LABEL");
const metaLeadEventName =
  cleanTrackingId(site?.metaLeadEventName) ?? envTrackingValue("PUBLIC_META_LEAD_EVENT_NAME") ?? "Lead";

const gtagLoaderId = gaMeasurementId ?? googleAdsConversionId;
const directGtagPageview = !gtmId;
const gtmInline = gtmId
  ? `(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer',${JSON.stringify(gtmId)});`
  : null;
const gtagConfigInline = gtagLoaderId
  ? `
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = window.gtag || gtag;
        gtag('js', new Date());
        ${gaMeasurementId ? `gtag('config', '${gaMeasurementId}', { send_page_view: ${directGtagPageview ? "true" : "false"} });` : ""}
        ${googleAdsConversionId ? `gtag('config', '${googleAdsConversionId}');` : ""}
      `
  : null;
const gtagShimInline = !gtagLoaderId
  ? `
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = window.gtag || gtag;
      `
  : null;
const metaPixelInline = metaPixelId
  ? `!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init',${JSON.stringify(metaPixelId)});fbq('track','PageView');`
  : null;
const marketingTrackingConfig = {
  googleAdsConversionId,
  googleAdsLeadConversionLabel,
  metaLeadEventName,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#041632" />
    <link rel="icon" href="/favicon.ico" />
    <title>{pageTitle}</title>

    <!-- Preconnect to Cloudinary for faster image loads -->
    <link rel="preconnect" href="https://res.cloudinary.com" />

    <!-- LCP image preload (per-page, injected by pages that need it) -->
    {preloadImage && (
      <link
        rel="preload"
        as="image"
        href={preloadImage}
        imagesrcset={preloadImageSrcset || undefined}
        imagesizes={preloadImageSizes || undefined}
        fetchpriority="high"
      />
    )}

    <!-- Font-face declarations inline — keeps fonts out of the CSS bundle -->
    <style is:inline>
      @font-face {
        font-family: "Manrope Variable";
        src: url("/fonts/manrope-vf.woff2") format("woff2-variations");
        font-weight: 200 800;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Inter Variable";
        src: url("/fonts/inter-vf.woff2") format("woff2-variations");
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Newsreader Variable";
        src: url("/fonts/newsreader-vf.woff2") format("woff2-variations");
        font-weight: 200 800;
        font-style: normal;
        font-display: swap;
      }
    </style>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content={authorName} />
    <meta name="publisher" content={authorName} />
    {keywords && keywords.length > 0 && (
      <meta name="keywords" content={keywords.join(", ")} />
    )}
    {resolvedCanonical && <link rel="canonical" href={resolvedCanonical} />}
    <link rel="alternate" hreflang="en" href={resolvedCanonical ?? `${siteBase}${cleanPath}`} />
    <link rel="alternate" hreflang="x-default" href={resolvedCanonical ?? `${siteBase}${cleanPath}`} />

    <!-- Site Verification -->
    {site?.googleVerification && (
      <meta name="google-site-verification" content={site.googleVerification} />
    )}
    {site?.bingVerification && (
      <meta name="msvalidate.01" content={site.bingVerification} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={resolvedOgType} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:url" content={resolvedCanonical ?? ""} />
    <meta property="og:site_name" content={companyName} />
    <meta property="og:logo" content={brandOgLogo} />
    <meta property="og:logo:width" content="512" />
    <meta property="og:logo:height" content="512" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content={resolvedOgImageWidth} />
    <meta property="og:image:height" content={resolvedOgImageHeight} />
    <meta property="og:image:alt" content={resolvedOgTitle} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTwitterTitle} />
    <meta name="twitter:description" content={resolvedTwitterDesc} />
    {site?.twitterHandle && <meta name="twitter:site" content={site.twitterHandle} />}
    <meta name="twitter:image" content={resolvedTwitterImage} />

    <!-- JSON-LD Structured Data -->
    {schemaArray && schemaArray.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Local Business / Organization Schema -->
    <LocalBusinessSchema company={company} site={site} />

    <!-- Breadcrumb Schema (skip on homepage) -->
    {breadcrumbs && breadcrumbs.length > 0 && (
      <BreadcrumbSchema items={breadcrumbs} />
    )}

    {marketingTrackingEnabled && gtmInline && (
      <script is:inline set:html={gtmInline} />
    )}
    {marketingTrackingEnabled && gtagLoaderId && (
      <script type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=${gtagLoaderId}`} />
      <script type="text/partytown" set:html={gtagConfigInline} />
    )}
    {marketingTrackingEnabled && !gtagLoaderId && gtagShimInline && (
      <script is:inline set:html={gtagShimInline} />
    )}
    {marketingTrackingEnabled && clarityId && (
      <script type="text/partytown" set:html={`window.clarity=window.clarity||function(){(window.clarity.q=window.clarity.q||[]).push(arguments)};`} />
      <script type="text/partytown" src={`https://www.clarity.ms/tag/${clarityId}`} />
    )}
    {marketingTrackingEnabled && metaPixelInline && (
      <script is:inline set:html={metaPixelInline} />
    )}
    {marketingTrackingEnabled && (
      <script is:inline set:html={`window.__AGE_TRACKING_CONFIG__=${JSON.stringify(marketingTrackingConfig)};`} />
    )}
    {marketingTrackingEnabled && (
      <script>
        import { initMarketingAttribution } from "../scripts/marketing-attribution";
        initMarketingAttribution((window as any).__AGE_TRACKING_CONFIG__ ?? {});
      </script>
    )}

    <style is:inline>
      @font-face {
        font-family: 'Material Symbols Outlined';
        font-style: normal;
        font-weight: 100 700;
        font-display: swap;
        src: url('/fonts/material-symbols-outlined.woff2') format('woff2');
      }
      .material-symbols-outlined {
        font-family: 'Material Symbols Outlined';
        font-weight: normal;
        font-style: normal;
        font-size: 24px;
        line-height: 1;
        letter-spacing: normal;
        text-transform: none;
        display: inline-block;
        white-space: nowrap;
        word-wrap: normal;
        direction: ltr;
        -webkit-font-feature-settings: 'liga';
        -webkit-font-smoothing: antialiased;
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>
  </head>
  <body class="min-h-screen bg-[var(--color-background)] text-[var(--color-text)]">
    {marketingTrackingEnabled && gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}
    {marketingTrackingEnabled && metaPixelId && (
      <noscript>
        <img
          height="1"
          width="1"
          style="display:none"
          src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`}
          alt=""
        />
      </noscript>
    )}
    {!hideHeader && <Header />}
    <main id="main-content" class={mainClass}>
      <slot />
    </main>
    {!hideFooter && <Footer />}
    {!hideProductInquiryRoot && <ProductInquiryRoot />}
    {!hideFloatingActions && <FloatingActions waMessage={waMessage} />}
    <!-- WhatsApp delegated click handler: opens data-wa-link URLs in a new tab -->
    <script is:inline>
      document.addEventListener('click', (e) => {
        const waBtn = e.target.closest('[data-wa-link]');
        if (waBtn) {
          const url = waBtn.getAttribute('data-wa-link');
          if (typeof window.ageTrack === 'function') {
            window.ageTrack('whatsapp_link_click', {
              page_path: window.location.pathname,
              link_url: url,
            });
          }
          window.open(url, '_blank', 'noopener,noreferrer');
        }
      });
    </script>
  </body>
</html>
