<section class="py-32 bg-[#f8f9fa]">
  <div class="max-w-7xl mx-auto px-8">
    <div class="mb-20 text-center">
      <h2 class="font-serif text-5xl text-[#041632]">The <span class="italic text-[#775a19]">Leadership</span> Team</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {leaders.map((l) => (
        <div class={`bg-[#f3f4f5] group overflow-hidden${l.offset ? " md:mt-12" : ""}`}>
          <div class="aspect-[3/4] overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-700">
            <img src={l.img} alt={`Portrait of ${l.name}`} class="w-full h-full object-cover" />
          </div>
          <div class="p-8">
            <h4 class="font-serif text-2xl text-[#041632]">{l.name}</h4>
            <p class="font-sans text-xs uppercase tracking-widest text-[#775a19] mt-1">{l.role}</p>
            <p class="text-[#44474d] text-sm mt-4 leading-relaxed">{l.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
