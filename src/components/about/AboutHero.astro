---
interface Props {
  image?: string | null;
}
const { image } = Astro.props;

function buildHeroUrl(url: string, width: number): string {
  if (!url.includes("res.cloudinary.com")) return url;
  const uploadIdx = url.indexOf("/upload/");
  if (uploadIdx === -1) return url;
  const base = url.slice(0, uploadIdx + "/upload/".length);
  const segments = url.slice(base.length).split("/");
  let i = 0;
  while (i < segments.length) {
    const seg = segments[i];
    if (/^v\d+$/.test(seg)) break;
    if (seg.includes(",") || /^[fqwchgbdeo]_/.test(seg)) { i++; } else break;
  }
  const publicPart = segments.slice(i).join("/");
  return `${base}f_auto,q_auto,w_${width},c_limit/${publicPart}`;
}

const FALLBACK_HERO = "https://res.cloudinary.com/age-fabric/image/upload/f_auto,q_60,w_1600,c_limit/About1_j3mzld.jpg";
const rawImage = image ?? FALLBACK_HERO;
const heroImage = buildHeroUrl(rawImage, 1600);
const heroSrcset = [400, 768, 1024, 1600].map((w) => `${buildHeroUrl(rawImage, w)} ${w}w`).join(", ");
---
<style>
  .gold-text {
    background: linear-gradient(to right, #775a19, #fed488);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
</style>
<header class="relative h-[870px] flex items-center overflow-hidden bg-[#041632] pt-16">
  <div class="absolute inset-0 opacity-70">
    <img
      src={heroImage}
      srcset={heroSrcset}
      sizes="100vw"
      alt="Industrial textile loom threads close up"
      title="Industrial textile loom threads close up"
      width="1600"
      height="870"
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#041632] via-[#041632]/60 to-transparent"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-8 w-full">
    <div class="max-w-3xl">
      <span class="inline-block px-4 py-1 mb-6 border border-[#775a19] text-[#ffdea5] font-sans text-xs tracking-[0.2em] uppercase">
        Est. 1971 | Ahmedabad, India
      </span>
      <h1 class="font-serif text-6xl md:text-7xl leading-tight mb-8">
        <span class="text-white">A Legacy of</span><br/>
        <span class="italic gold-text">Textile Excellence</span><br/>
        <span class="text-white">Since 1971</span>
      </h1>
      <p class="text-[#8393b5] text-xl md:text-2xl leading-relaxed font-light mb-10 max-w-2xl">
        For over five decades, Amrita Global Enterprises has defined the intersection of technical precision and artistic mastery in the global fabric industry.
      </p>
    </div>
  </div>
  <div class="absolute bottom-12 right-12 hidden lg:block">
    <div class="flex items-center gap-4 text-[#775a19] rotate-90 origin-right">
      <span class="font-sans tracking-widest text-xs uppercase">Scroll to Explore</span>
      <div class="w-12 h-px bg-[#775a19]"></div>
    </div>
  </div>
</header>
