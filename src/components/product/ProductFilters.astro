---
interface ColorItem { name: string; hex: string; }

interface Props {
  categories: string[];
  colors: ColorItem[];
  structures: string[];
  contents: string[];
  designs: string[];
  finishes: string[];
  preSelectedCategory?: string;
}

const { categories, colors, structures, contents, designs, finishes, preSelectedCategory } = Astro.props;

// Normalize for comparison (case-insensitive, handles "Denim Fabric" vs "Denim Fabrics")
function isPreSelected(value: string): boolean {
  if (!preSelectedCategory) return false;
  const a = value.toLowerCase().trim();
  const b = preSelectedCategory.toLowerCase().trim();
  return a === b || a.includes(b) || b.includes(a);
}
---

<style>
  .filter-scroll {
    scrollbar-width: thin;
    scrollbar-color: #cbd5e1 transparent;
  }
  .filter-scroll::-webkit-scrollbar {
    width: 4px;
  }
  .filter-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .filter-scroll::-webkit-scrollbar-thumb {
    background-color: #cbd5e1;
    border-radius: 9999px;
  }
  .filter-scroll::-webkit-scrollbar-thumb:hover {
    background-color: #94a3b8;
  }
  /* Outer panel scroll on desktop sticky sidebar */
  .filter-panel-outer {
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #e2e8f0 transparent;
  }
  .filter-panel-outer::-webkit-scrollbar {
    width: 4px;
  }
  .filter-panel-outer::-webkit-scrollbar-track {
    background: transparent;
  }
  .filter-panel-outer::-webkit-scrollbar-thumb {
    background-color: #e2e8f0;
    border-radius: 9999px;
  }
  .filter-panel-outer::-webkit-scrollbar-thumb:hover {
    background-color: #cbd5e1;
  }
</style>

<div class="filter-panel-outer">
<div class="filter-panel space-y-6 pr-1">

  <!-- Clear All — hidden until a filter is active -->
  <button
    id="clear-filters"
    class="hidden items-center gap-1.5 text-xs text-[#775a19] underline underline-offset-2 hover:text-[#041632] transition"
  >
    <span class="material-symbols-outlined text-sm">filter_alt_off</span>
    Clear filters
  </button>

  <!-- 1. Category -->
  {categories.length > 0 && (
    <div>
      <h3 class="mb-3 border-b border-slate-200 pb-2 text-xs font-label font-bold uppercase tracking-widest text-[#041632]">Category</h3>
      <ul class="max-h-48 overflow-y-auto space-y-2 pr-1 filter-scroll">
        {categories.map((item) => (
          <li>
            <label class="flex cursor-pointer items-center gap-3 text-sm font-medium text-slate-600 hover:text-[#041632]">
              <input type="checkbox" data-filter-field="category" data-filter-value={item} class="filter-checkbox rounded border-slate-300 text-[#775a19] focus:ring-[#775a19]" checked={isPreSelected(item)} />
              {item}
            </label>
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- 2. Structure / Weave -->
  {structures.length > 0 && (
    <div>
      <h3 class="mb-3 border-b border-slate-200 pb-2 text-xs font-label font-bold uppercase tracking-widest text-[#041632]">Structure / Weave</h3>
      <ul class="max-h-48 overflow-y-auto space-y-2 pr-1 filter-scroll">
        {structures.map((item) => (
          <li>
            <label class="flex cursor-pointer items-center gap-3 text-sm font-medium text-slate-600 hover:text-[#041632]">
              <input type="checkbox" data-filter-field="structure" data-filter-value={item} class="filter-checkbox rounded border-slate-300 text-[#775a19] focus:ring-[#775a19]" />
              {item}
            </label>
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- 4. Content -->
  {contents.length > 0 && (
    <div>
      <h3 class="mb-3 border-b border-slate-200 pb-2 text-xs font-label font-bold uppercase tracking-widest text-[#041632]">Content</h3>
      <ul class="max-h-48 overflow-y-auto space-y-2 pr-1 filter-scroll">
        {contents.map((item) => (
          <li>
            <label class="flex cursor-pointer items-center gap-3 text-sm font-medium text-slate-600 hover:text-[#041632]">
              <input type="checkbox" data-filter-field="content" data-filter-value={item} class="filter-checkbox rounded border-slate-300 text-[#775a19] focus:ring-[#775a19]" />
              {item}
            </label>
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- 5. Design -->
  {designs.length > 0 && (
    <div>
      <h3 class="mb-3 border-b border-slate-200 pb-2 text-xs font-label font-bold uppercase tracking-widest text-[#041632]">Design</h3>
      <ul class="max-h-48 overflow-y-auto space-y-2 pr-1 filter-scroll">
        {designs.map((item) => (
          <li>
            <label class="flex cursor-pointer items-center gap-3 text-sm font-medium text-slate-600 hover:text-[#041632]">
              <input type="checkbox" data-filter-field="design" data-filter-value={item} class="filter-checkbox rounded border-slate-300 text-[#775a19] focus:ring-[#775a19]" />
              {item}
            </label>
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- 6. Color — one per row, swatch + name, scrollable -->
  {colors.length > 0 && (
    <div>
      <h3 class="mb-3 border-b border-slate-200 pb-2 text-xs font-label font-bold uppercase tracking-widest text-[#041632]">Color</h3>
      <ul class="max-h-52 overflow-y-auto space-y-2 pr-1 filter-scroll">
        {colors.map((c) => (
          <li>
            <label class="flex cursor-pointer items-center gap-3 text-sm font-medium text-slate-600 hover:text-[#041632]">
              <input type="checkbox" data-filter-field="color" data-filter-value={c.name} class="filter-checkbox sr-only" />
              <span
                class="color-dot h-4 w-4 flex-shrink-0 rounded-full ring-1 ring-slate-300 transition"
                style={`background-color:${c.hex};`}
              />
              {c.name}
            </label>
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- 7. Core Finishes -->
  {finishes.length > 0 && (
    <div>
      <h3 class="mb-3 border-b border-slate-200 pb-2 text-xs font-label font-bold uppercase tracking-widest text-[#041632]">Core Finishes</h3>
      <ul class="max-h-48 overflow-y-auto space-y-2 pr-1 filter-scroll">
        {finishes.map((item) => (
          <li>
            <label class="flex cursor-pointer items-center gap-3 text-sm font-medium text-slate-600 hover:text-[#041632]">
              <input type="checkbox" data-filter-field="finish" data-filter-value={item} class="filter-checkbox rounded border-slate-300 text-[#775a19] focus:ring-[#775a19]" />
              {item}
            </label>
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- 7. Weight (GSM) -->
  <div>
    <h3 class="mb-3 border-b border-slate-200 pb-2 text-xs font-label font-bold uppercase tracking-widest text-[#041632]">Weight (GSM)</h3>
    <label for="gsm-range" class="sr-only">Maximum weight in GSM</label>
    <input id="gsm-range" type="range" min="50" max="500" value="500" class="w-full accent-[#775a19]" />
    <div class="mt-2 flex justify-between font-mono text-[10px] uppercase text-slate-500">
      <span>50 GSM</span>
      <span id="gsm-value">500 GSM</span>
    </div>
  </div>

</div>
</div>

<script>
  const active = new Map<string, Set<string>>();
  let maxGsm = 500;

  function hasActiveFilters(): boolean {
    return [...active.values()].some((s) => s.size > 0) || maxGsm < 500;
  }

  function updateClearBtn(): void {
    const btn = document.getElementById("clear-filters");
    if (!btn) return;
    btn.classList.toggle("hidden", !hasActiveFilters());
    btn.classList.toggle("flex", hasActiveFilters());
  }

  function applyFilters(): void {
    const grid = document.getElementById("product-grid");

    // Tell infinite-scroll to pause while we're filtering
    if (typeof (window as any).__setFiltering === "function") {
      (window as any).__setFiltering(true);
    }

    // Capture scroll position and pin grid height BEFORE hiding cards
    const scrollY = window.scrollY;
    if (grid) grid.style.minHeight = grid.offsetHeight + "px";

    let visible = 0;
    document.querySelectorAll<HTMLElement>(".product-card").forEach((card) => {
      const passes =
        matchField("category", card.dataset.category ?? "") &&
        matchField("color",    card.dataset.color ?? "") &&
        matchField("structure",card.dataset.structure ?? "") &&
        matchField("content",  card.dataset.content ?? "") &&
        matchField("design",   card.dataset.design ?? "") &&
        matchField("finish",   card.dataset.finish ?? "") &&
        parseInt(card.dataset.gsm ?? "0", 10) <= maxGsm;
      card.style.display = passes ? "" : "none";
      if (passes) visible++;
    });

    // Update toolbar count
    const countEl = document.getElementById("toolbar-count");
    if (countEl) {
      const total = parseInt(countEl.dataset.total ?? "0", 10);
      countEl.textContent = hasActiveFilters()
        ? `Showing ${visible} of ${total} textiles`
        : `Showing all ${total} textiles`;
    }

    // Show/hide no-results message
    const noResults = document.getElementById("no-results");
    if (noResults) noResults.classList.toggle("hidden", visible > 0);

    // After two frames: restore scroll, release min-height, re-enable infinite-scroll
    requestAnimationFrame(() => requestAnimationFrame(() => {
      window.scrollTo({ top: scrollY, behavior: "instant" });
      if (grid) grid.style.minHeight = "";
      if (typeof (window as any).__setFiltering === "function") {
        (window as any).__setFiltering(false);
      }
    }));
  }

  // Expose globally so infinite-scroll can call after injecting new cards
  (window as any).__applyFilters = applyFilters;

  function matchField(field: string, value: string): boolean {
    const set = active.get(field);
    if (!set || set.size === 0) return true;
    return [...set].some((v) => value.toLowerCase().includes(v.toLowerCase()));
  }

  // Initialize active map from any server-rendered checked checkboxes (preSelectedCategory)
  // AND from URL query param as fallback
  function initFromUrl(): void {
    // First: pick up any checkboxes already checked server-side
    document.querySelectorAll<HTMLInputElement>(".filter-checkbox:checked").forEach((cb) => {
      const field = cb.dataset.filterField ?? "";
      const val = cb.dataset.filterValue ?? "";
      if (!active.has(field)) active.set(field, new Set());
      active.get(field)!.add(val);
    });

    // Second: also check URL param (for /fabric?category= links)
    const urlParams = new URLSearchParams(window.location.search);
    const preCategory = urlParams.get("category");
    if (preCategory) {
      document.querySelectorAll<HTMLInputElement>('.filter-checkbox[data-filter-field="category"]').forEach((cb) => {
        const cbVal = (cb.dataset.filterValue ?? "").toLowerCase();
        const urlVal = preCategory.toLowerCase();
        if (cbVal.includes(urlVal) || urlVal.includes(cbVal)) {
          cb.checked = true;
          if (!active.has("category")) active.set("category", new Set());
          active.get("category")!.add(cb.dataset.filterValue ?? "");
        }
      });
    }

    if (hasActiveFilters()) {
      applyFilters();
      updateClearBtn();
    }
  }

  // Run after DOM is fully parsed — setTimeout(0) pushes to next tick as safety net
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFromUrl);
  } else {
    setTimeout(initFromUrl, 0);
  }

  document.querySelectorAll<HTMLInputElement>(".filter-checkbox").forEach((cb) => {
    const label = cb.closest("label");

    // Intercept the label click: prevent the browser's default focus+scroll,
    // manually toggle the checkbox, then fire change ourselves.
    label?.addEventListener("click", (e) => {
      e.preventDefault();
      cb.checked = !cb.checked;
      cb.focus({ preventScroll: true });
      cb.dispatchEvent(new Event("change", { bubbles: true }));
    });

    cb.addEventListener("change", () => {
      const field = cb.dataset.filterField ?? "";
      const val   = cb.dataset.filterValue ?? "";
      if (!active.has(field)) active.set(field, new Set());
      const set = active.get(field)!;
      cb.checked ? set.add(val) : set.delete(val);

      const dot = label?.querySelector<HTMLElement>(".color-dot");
      if (dot) {
        dot.style.outline = cb.checked ? "2px solid #775a19" : "";
        dot.style.outlineOffset = cb.checked ? "2px" : "";
      }
      applyFilters();
      updateClearBtn();
    });
  });

  const gsmRange = document.getElementById("gsm-range") as HTMLInputElement | null;
  const gsmLabel = document.getElementById("gsm-value") as HTMLElement | null;

  gsmRange?.addEventListener("input", () => {
    maxGsm = parseInt(gsmRange.value, 10);
    if (gsmLabel) gsmLabel.textContent = `${maxGsm} GSM`;
    applyFilters();
    updateClearBtn();
  });

  document.getElementById("clear-filters")?.addEventListener("click", () => {
    document.querySelectorAll<HTMLInputElement>(".filter-checkbox").forEach((cb) => {
      cb.checked = false;
      const dot = cb.closest("label")?.querySelector<HTMLElement>(".color-dot");
      if (dot) { dot.style.outline = ""; dot.style.outlineOffset = ""; }
    });
    active.clear();
    maxGsm = 500;
    if (gsmRange) gsmRange.value = "500";
    if (gsmLabel) gsmLabel.textContent = "500 GSM";
    applyFilters();
    updateClearBtn();
  });
</script>
