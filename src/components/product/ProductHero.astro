---
import ResponsiveImage from "../common/ResponsiveImage.astro";
import { WA_FALLBACK, PHONE_FALLBACK } from "../../lib/constants";
const SALES_EMAIL = "sales@egport.com";
---

<header class="relative flex h-[250px] items-center overflow-hidden md:h-[300px]">
  <div class="absolute inset-0 bg-[#041632]/40 z-10"></div>
  <ResponsiveImage
    src="https://res.cloudinary.com/age-fabric/image/upload/v1775652305/17_y6ajol.jpg"
    alt="Fabric catalog banner"
    width={1600}
    height={600}
    sizes="100vw"
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
    fetchpriority="high"
  />
  <div class="relative z-20 mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
    <h1 class="font-headline italic text-3xl text-white tracking-tight md:text-5xl">
      Browse Our Full Fabric Catalog
    </h1>
    <nav class="mt-4 flex items-center gap-2 text-[10px] font-label font-medium uppercase tracking-widest text-white/80 md:text-sm">
      <a href="/" class="transition hover:text-white">Home</a>
      <span>/</span>
      <a href="/fabric" class="font-bold text-white">Shop</a>
    </nav>
    <!-- CTA buttons: WhatsApp, Call, Email -->
    <div class="flex flex-wrap gap-3 mt-5">
      <a
        id="product-hero-whatsapp-btn"
        href={WA_FALLBACK}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 bg-white/10 border border-white/30 backdrop-blur-sm text-white px-4 py-2 hover:bg-white/20 transition-all text-sm font-label font-semibold"
      >
        <span class="material-symbols-outlined text-green-400 text-base" style="font-variation-settings: 'FILL' 1;">chat</span>
        WhatsApp
      </a>
      <a
        href={PHONE_FALLBACK}
        class="flex items-center gap-2 bg-white/10 border border-white/30 backdrop-blur-sm text-white px-4 py-2 hover:bg-white/20 transition-all text-sm font-label font-semibold"
      >
        <span class="material-symbols-outlined text-base">call</span>
        Call Us
      </a>
      <a
        id="product-hero-email-btn"
        href="#"
        class="flex items-center gap-2 bg-white/10 border border-white/30 backdrop-blur-sm text-white px-4 py-2 hover:bg-white/20 transition-all text-sm font-label font-semibold"
      >
        <span class="material-symbols-outlined text-[#ecc15c] text-base">mail</span>
        Email
      </a>
    </div>
  </div>
</header>

<script>
  const SALES_EMAIL = "sales@egport.com";

  const emailBtn = document.getElementById("product-hero-email-btn") as HTMLAnchorElement | null;
  const waBtn    = document.getElementById("product-hero-whatsapp-btn") as HTMLAnchorElement | null;

  if (emailBtn) {
    const pageUrl = window.location.href;
    const subject = encodeURIComponent("Fabric Catalog Inquiry");
    const body    = encodeURIComponent(
      `Hi,\n\nI am interested in your fabric catalog.\n\n${pageUrl}\n\nPlease share more details.\n\nThank you.`
    );
    emailBtn.href = `mailto:${SALES_EMAIL}?subject=${subject}&body=${body}`;
  }

  if (waBtn) {
    const pageUrl  = window.location.href;
    const baseHref = waBtn.href.split("?")[0];
    const message  = encodeURIComponent(`Hi, I'm browsing your fabric catalog:\n${pageUrl}`);
    waBtn.href = `${baseHref}?text=${message}`;
  }
</script>