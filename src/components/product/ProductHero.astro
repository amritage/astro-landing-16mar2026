---
import ResponsiveImage from "../common/ResponsiveImage.astro";

---

<header class="relative flex h-[250px] items-center overflow-hidden md:h-[300px]">
  <div class="absolute inset-0 bg-[#041632]/40 z-10"></div>
  <ResponsiveImage
    src="https://res.cloudinary.com/age-fabric/image/upload/v1775652305/17_y6ajol.jpg"
    alt="Fabric catalog banner"
    width={1600}
    height={600}
    sizes="100vw"
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
    fetchpriority="high"
  />
  <div class="relative z-20 mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
    <h1 class="font-headline italic text-3xl text-white tracking-tight md:text-5xl">
      Browse Our Full Fabric Catalog
    </h1>
    <nav class="mt-4 flex items-center gap-2 text-[10px] font-label font-medium uppercase tracking-widest text-white/80 md:text-sm">
      <a href="/" class="transition hover:text-white">Home</a>
      <span>/</span>
      <a href="/fabric" class="font-bold text-white">Shop</a>
    </nav>
  </div>
</header>