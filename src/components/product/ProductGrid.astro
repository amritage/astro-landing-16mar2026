---
import ProductCard from "./ProductCard.astro";
import productGridScript from "../../scripts/product-grid.js?url";

interface Product {
  id: string;
  name: string;
  category: string;
  weight: string;
  width: string;
  color: string;
  image: string;
  imageSrcset?: string;
  href: string | null;
  filterCategory?: string;
  filterColor?: string;
  filterStructure?: string;
  filterContent?: string;
  filterGsm?: string;
  filterDesign?: string;
  filterFinish?: string;
  searchSlug?: string;
  searchOzs?: string;
  searchCm?: string;
  searchInch?: string;
  searchMotif?: string;
  searchKeywords?: string;
  searchMerchTags?: string;
  searchCollection?: string;
  searchSupply?: string;
  searchFabricCode?: string;
  searchVendorCode?: string;
  searchMOQ?: string;
}

interface Props {
  products: Product[];
  currentPage?: number;
  totalPages?: number;
  baseUrl?: string;
}

const { products } = Astro.props;

// First batch rendered visible, rest scroll-hidden — revealed by IntersectionObserver
const INITIAL_BATCH = 12;
---

<div id="product-grid">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3" id="product-grid-inner">
    {products.map((product, i) => (
      <div
        class="product-card-wrapper"
        data-scroll-hidden={i >= INITIAL_BATCH ? "true" : undefined}
        style={i >= INITIAL_BATCH ? "display:none" : undefined}
      >
        <ProductCard product={product} />
      </div>
    ))}
  </div>

  <!-- Scroll sentinel — IntersectionObserver watches this to load next batch -->
  <div id="scroll-sentinel" class="h-4 w-full" aria-hidden="true"></div>

  <!-- Loading indicator: populated by JS only while loading -->
  <div
    id="load-more-indicator"
    data-nosnippet
    aria-live="polite"
    style="display:none"
    class="justify-center py-8"
  ></div>

  <!-- Empty state: populated by JS only after filtering returns zero matches -->
  <div
    id="no-results"
    data-nosnippet
    aria-live="polite"
    class="hidden flex-col items-center justify-center py-24 text-center"
  ></div>
</div>

<script type="module" src={productGridScript}></script>
