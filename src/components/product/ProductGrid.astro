---
import ProductCard from "./ProductCard.astro";

interface Product {
  id: string;
  name: string;
  category: string;
  weight: string;
  width: string;
  color: string;
  image: string;
  imageSrcset?: string;
  href: string;
  filterCategory?: string;
  filterColor?: string;
  filterStructure?: string;
  filterContent?: string;
  filterGsm?: string;
  filterDesign?: string;
  filterFinish?: string;
}

interface Props {
  products: Product[];
  // kept for API compatibility but no longer used for pagination
  currentPage?: number;
  totalPages?: number;
  baseUrl?: string;
}

const { products } = Astro.props;

// Initial batch: first 9 products (3 rows of 3). Rest loaded via IntersectionObserver.
const INITIAL_COUNT = 9;
const initialProducts = products.slice(0, INITIAL_COUNT);
const deferredProducts = products.slice(INITIAL_COUNT);
---

<div>
  <div id="product-grid" class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
    {initialProducts.map((product) => (
      <ProductCard product={product} />
    ))}
  </div>

  <!-- Sentinel: triggers loading more cards when scrolled into view -->
  {deferredProducts.length > 0 && (
    <div id="load-more-sentinel" class="h-4 w-full" aria-hidden="true"></div>
  )}

  <!-- Hidden container holding serialised product data for JS to pick up -->
  {deferredProducts.length > 0 && (
    <script
      id="deferred-products-data"
      type="application/json"
      set:html={JSON.stringify(deferredProducts)}
    />
  )}

  <!-- No-results message (shown by filter JS when nothing matches) -->
  <div id="no-results" class="hidden py-24 text-center">
    <span class="material-symbols-outlined text-5xl text-slate-300 mb-4 block">search_off</span>
    <p class="font-headline text-xl text-slate-400">No products match your filters</p>
    <button
      id="clear-filters-inline"
      class="mt-6 text-xs font-label font-bold uppercase tracking-widest text-[#775a19] underline underline-offset-4"
    >
      Clear all filters
    </button>
  </div>
</div>

<script>
  // ── Infinite scroll ──────────────────────────────────────────────────────────
  const sentinel = document.getElementById("load-more-sentinel");
  const grid = document.getElementById("product-grid") as HTMLElement | null;
  const dataEl = document.getElementById("deferred-products-data");

  if (sentinel && grid && dataEl) {
    const deferred: Array<Record<string, string>> = JSON.parse(dataEl.textContent ?? "[]");
    const BATCH = 9; // cards to inject per scroll trigger
    let loaded = 0;
    let filteringInProgress = false;

    // Expose a flag so applyFilters can pause infinite-scroll during filter ops
    (window as any).__setFiltering = (val: boolean) => { filteringInProgress = val; };

    function buildCard(p: Record<string, string>): string {
      const href = p.href ?? "";
      const hasLink = href && href !== "null";
      return `
        <article
          class="product-card group cursor-pointer overflow-hidden rounded bg-white shadow-sm transition-all hover:shadow-xl"
          data-category="${p.filterCategory ?? p.category ?? ""}"
          data-color="${p.filterColor ?? ""}"
          data-structure="${p.filterStructure ?? ""}"
          data-content="${p.filterContent ?? ""}"
          data-design="${p.filterDesign ?? ""}"
          data-finish="${p.filterFinish ?? ""}"
          data-gsm="${p.filterGsm ?? "0"}"
        >
          <a href="${hasLink ? href : ""}" class="block${hasLink ? "" : " pointer-events-none"}">
            <div class="relative h-64 overflow-hidden bg-slate-100">
              <img
                src="${p.image ?? ""}"
                alt="${p.name ?? ""}"
                title="${p.name ?? ""}"
                width="400"
                height="267"
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              />
              <span class="absolute right-4 top-4 bg-[#041632] px-2 py-1 text-[10px] font-mono uppercase tracking-widest text-white">
                ID: ${p.id}
              </span>
            </div>
            <div class="p-6">
              <div class="mb-2 flex items-start justify-between">
                <p class="text-[10px] font-label font-bold uppercase tracking-widest text-[#775a19]">${p.category ?? ""}</p>
              </div>
              <h3 class="font-headline text-base leading-snug text-[#041632] line-clamp-3">${p.name ?? ""}</h3>
              <div class="mt-4 flex gap-6 text-xs text-slate-500">
                <div><span class="block font-label font-bold uppercase tracking-widest text-[10px]">Weight</span>${p.weight ?? ""}</div>
                <div><span class="block font-label font-bold uppercase tracking-widest text-[10px]">Width</span>${p.width ?? ""}</div>
              </div>
              <div class="mt-5 border-t border-slate-100 pt-4">
                <span class="inline-block w-full bg-[#041632] px-4 py-2.5 text-center text-[10px] font-label font-bold uppercase tracking-widest text-white transition hover:bg-[#775a19]">
                  View Specifications
                </span>
              </div>
            </div>
          </a>
        </article>`;
    }

    function loadBatch(): void {
      const batch = deferred.slice(loaded, loaded + BATCH);
      if (batch.length === 0) {
        observer.disconnect();
        sentinel.remove();
        return;
      }
      const frag = document.createDocumentFragment();
      batch.forEach((p) => {
        const div = document.createElement("div");
        div.innerHTML = buildCard(p);
        const card = div.firstElementChild as HTMLElement;
        frag.appendChild(card);
      });
      grid.appendChild(frag);
      loaded += batch.length;

      // Re-run active filters on newly added cards
      if (typeof (window as any).__applyFilters === "function") {
        (window as any).__applyFilters();
      }

      if (loaded >= deferred.length) {
        observer.disconnect();
        sentinel.remove();
      }
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !filteringInProgress) loadBatch();
      },
      { rootMargin: "300px" }
    );
    observer.observe(sentinel);
  }
</script>
