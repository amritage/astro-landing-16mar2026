---
export interface FAQItem {
  question: string;
  answer: string;
}

export interface Props {
  heading?: string;
  faqs?: FAQItem[];
}

const {
  heading = "Common Inquiries",
  faqs = [
    {
      question: "What are the minimum export volumes?",
      answer: "We cater to both mid-scale and massive volume requests. Typical MOQ for international export starts at 5,000 meters per specification to maintain cost efficiency.",
    },
    {
      question: "Do you offer custom weaving patterns?",
      answer: "Yes, our R&D facility in Ahmedabad allows for custom Dobby and Jacquard patterns tailored to specific brand identities.",
    },
  ],
} = Astro.props;
---

<section class="py-20 px-6 bg-[#f8f9fa]">
  <h2 class="font-headline text-3xl text-[#041632] mb-8">{heading}</h2>
  <div class="space-y-4 max-w-2xl">
    {faqs.map((faq, i) => (
      <details class="group bg-white border border-[#d9dfe5] rounded-2xl overflow-hidden shadow-sm" open={i === 0}>
        <summary class="flex justify-between items-center p-5 cursor-pointer list-none">
          <span class="font-body font-semibold text-[#041632] pr-4">{faq.question}</span>
          <span class="material-symbols-outlined text-[#8d6708] transition-transform duration-200 group-open:rotate-180 shrink-0">expand_more</span>
        </summary>
        <div class="px-5 pb-5 text-sm text-[#44474d] leading-relaxed">{faq.answer}</div>
      </details>
    ))}
  </div>
</section>
