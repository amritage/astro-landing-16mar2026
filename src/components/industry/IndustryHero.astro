---
import Breadcrumbs from "../common/Breadcrumbs.astro";

export interface Props {
  badge?: string;
  title?: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  breadcrumbs?: { name: string; href?: string }[];
}

const {
  badge = "Industrial Excellence since 1971",
  title = "Precision Weaving for Global Markets.",
  subtitle = "Providing bespoke textile solutions to over 50+ countries with unparalleled craftsmanship.",
  image = "https://res.cloudinary.com/age-fabric/image/upload/v1775636524/Industries_cssian.jpg",
  imageAlt = "Industrial textile manufacturing loom in motion",
  breadcrumbs,
} = Astro.props;
---

<section class="relative h-[618px] flex items-end overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img class="w-full h-full object-cover" src={image} alt={imageAlt} width="1440" height="618" loading="eager" />
    <div class="absolute inset-0" style="background: linear-gradient(to top, #041632 0%, rgba(4,22,50,0.55) 50%, transparent 100%);"></div>
  </div>
  <div class="relative z-10 px-6 pb-12 w-full">
    {breadcrumbs && breadcrumbs.length > 1 && (
      <div class="mb-4">
        <Breadcrumbs items={breadcrumbs} variant="dark" />
      </div>
    )}
    <div class="inline-flex items-center px-3 py-1 mb-4 rounded-full bg-[#8d6708]/20 border border-[#8d6708]/30">
      <span class="font-label text-[10px] font-semibold text-[#e8b84b] tracking-widest uppercase">{badge}</span>
    </div>
    <h1 class="font-headline text-4xl md:text-5xl !text-white leading-tight mb-4">{title}</h1>
    <p class="font-body text-[#b7c7eb] max-w-md opacity-90 text-base">{subtitle}</p>
  </div>
</section>
