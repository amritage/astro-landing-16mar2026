---
export interface CompareRow {
  attribute: string;
  hospitality: boolean;
  uniforms: boolean;
}

export interface Props {
  heading?: string;
  subheading?: string;
  rows?: CompareRow[];
}

const {
  heading = "Sector Capability",
  subheading = "Performance metrics across industries.",
  rows = [
    { attribute: "Longevity",   hospitality: true,  uniforms: true  },
    { attribute: "Softness",    hospitality: true,  uniforms: false },
    { attribute: "Heat Resist", hospitality: false, uniforms: true  },
  ],
} = Astro.props;
---

<section class="py-20 bg-[#f6f7f8]">
  <div class="px-6 mb-8">
    <h2 class="font-headline text-3xl text-[#041632] mb-1">{heading}</h2>
    <p class="text-sm text-[#44474d]">{subheading}</p>
  </div>
  <div class="overflow-x-auto px-6">
    <table class="w-full border-collapse">
      <thead>
        <tr class="bg-[#041632] text-[#ffffff]">
          <th class="p-4 text-left font-headline text-sm font-normal rounded-tl-xl">Attribute</th>
          <th class="p-4 text-center font-headline text-sm font-normal">Hospitality</th>
          <th class="p-4 text-center font-headline text-sm font-normal rounded-tr-xl">Uniforms</th>
        </tr>
      </thead>
      <tbody class="text-sm">
        {rows.map((row, i) => (
          <tr class={`border-b border-[#d9dfe5] ${i % 2 === 0 ? "bg-white" : "bg-[#f3f4f6]"}`}>
            <td class="p-4 font-body font-semibold text-[#041632]">{row.attribute}</td>
            <td class="p-4 text-center">
              {row.hospitality
                ? <span class="material-symbols-outlined text-[#8d6708]" style="font-variation-settings:'FILL' 1">star</span>
                : <span class="material-symbols-outlined text-[#c7cdd4]">star</span>
              }
            </td>
            <td class="p-4 text-center">
              {row.uniforms
                ? <span class="material-symbols-outlined text-[#8d6708]" style="font-variation-settings:'FILL' 1">star</span>
                : <span class="material-symbols-outlined text-[#c7cdd4]">star</span>
              }
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
