---
export interface Props {
  heading?: string;
}

const { heading = "Sectors We Empower" } = Astro.props;
---

<section class="py-20 px-6 bg-[#f8f9fa]">
  <div class="mb-12">
    <h2 class="font-headline text-3xl text-[#041632] mb-2">{heading}</h2>
    <div class="h-1 w-12 rounded-full bg-[#8d6708]"></div>
  </div>

  <div class="grid grid-cols-1 gap-4">
    <!-- Apparel -->
    <div class="bg-white border border-[#d9dfe5] p-6 rounded-2xl flex flex-col justify-between h-64 shadow-sm">
      <div>
        <span class="material-symbols-outlined text-3xl mb-4 block text-[#8d6708]">checkroom</span>
        <h3 class="font-headline text-2xl text-[#041632]">Apparel</h3>
        <p class="text-sm mt-2 text-[#44474d]">High-street fashion and luxury ready-to-wear essentials.</p>
      </div>
      <div class="flex justify-between items-center pt-4 border-t border-[#d9dfe5]">
        <span class="font-label text-xs font-semibold uppercase tracking-wider text-[#8d6708]">Premium Finish</span>
        <span class="material-symbols-outlined text-[#041632]">arrow_forward</span>
      </div>
    </div>

    <!-- Hospitality -->
    <div class="bg-[#041632] p-6 rounded-2xl flex flex-col justify-between h-64 shadow-sm">
      <div>
        <span class="material-symbols-outlined text-3xl mb-4 block text-[#e8b84b]">bed</span>
        <h3 class="font-headline text-2xl text-[#ffffff]">Hospitality</h3>
        <p class="text-sm mt-2 text-[#b7c7eb]">Durable, high-thread count linens for elite global chains.</p>
      </div>
      <div class="flex justify-between items-center pt-4 border-t border-white/15">
        <span class="font-label text-xs font-semibold uppercase tracking-wider text-[#e8b84b]">Commercial Grade</span>
        <span class="material-symbols-outlined text-[#ffffff]">arrow_forward</span>
      </div>
    </div>

    <!-- Export & Uniforms -->
    <div class="grid grid-cols-2 gap-4">
      <div class="bg-[#eceff1] p-5 rounded-2xl flex flex-col gap-2">
        <span class="material-symbols-outlined text-[#041632]">public</span>
        <h3 class="font-headline text-lg text-[#041632]">Export</h3>
        <p class="text-xs text-[#44474d] leading-tight">Serving 50+ countries with logistics mastery.</p>
      </div>
      <div class="bg-[#fef3c7] p-5 rounded-2xl flex flex-col gap-2">
        <span class="material-symbols-outlined text-[#8d6708]">badge</span>
        <h3 class="font-headline text-lg text-[#041632]">Uniforms</h3>
        <p class="text-xs text-[#44474d] leading-tight">Strength meets professional aesthetics.</p>
      </div>
    </div>
  </div>
</section>
