<section class="px-8 mb-24 max-w-7xl mx-auto">
  <h3 class="font-serif text-3xl text-[#041632] mb-10 border-b border-[#c5c6ce] pb-4">Latest Archives</h3>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-8">

    <!-- Card 1 — Large -->
    <div class="md:col-span-7 bg-[#f3f4f5] rounded-xl overflow-hidden group">
      <div class="h-64 overflow-hidden">
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuByU9N-TLCkNz1HquVslgzw__Rgm85WQjYY7jzgYgsT73fH6J7xpjr-w3IGcDcPq0HnA1wptMA5FQtWdDOYuZqDGWL9uiU56qlFRGPtT0dpZGbcCv_SRPm7X8FhITD1pRQlfpgi9Iv5i6axBROToFMVntlIdWsC-0q4yqsiVFYH98_P3OmufASZaNEZ03MH5e23cAr_l7iw00PrtKB4v0VK_EMyAnyg72su2QjkFCgkI4Jzb4CiOua7m5omMa1n6p_kruxri1IKgjs8"
          alt="Technician examining high quality textile rolls"
          class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
        />
      </div>
      <div class="p-8">
        <div class="flex items-center gap-4 mb-4">
          <span class="font-sans text-[10px] font-bold text-[#775a19] uppercase tracking-widest">Market Trends</span>
          <span class="w-1 h-1 bg-[#c5c6ce] rounded-full"></span>
          <span class="font-sans text-[10px] text-[#75777e] uppercase">March 12, 2024</span>
        </div>
        <h4 class="font-serif text-2xl text-[#041632] font-bold mb-4">
          The 1971 Legacy: Scaling Quality in a Globalized Economy
        </h4>
        <p class="text-[#44474d] font-sans mb-6 line-clamp-2 text-sm">
          How Amrita Global maintains the artisanal integrity of Ahmedabad's textile history while meeting mass-scale global demands.
        </p>
        <a href="/blog/1971-legacy" class="font-sans text-xs font-bold text-[#041632] border-b-2 border-[#041632]/20 hover:border-[#775a19] transition-colors pb-1 uppercase tracking-tighter">
          Read Article
        </a>
      </div>
    </div>

    <!-- Card 2 — Vertical stack -->
    <div class="md:col-span-5 flex flex-col gap-8">
      <div class="bg-white p-8 rounded-xl shadow-sm border-t-2 border-[#775a19]/20">
        <span class="font-sans text-[10px] font-bold text-[#775a19] uppercase tracking-widest mb-3 block">Technology</span>
        <h4 class="font-serif text-xl text-[#041632] font-bold mb-4">
          Sustainable Synthetics: The Zero-Waste Loom Initiative
        </h4>
        <p class="text-[#44474d] font-sans text-sm line-clamp-3">
          Our latest report on reducing water consumption in industrial dying processes through localized filtration tech.
        </p>
      </div>
      <div class="bg-[#041632] text-white p-8 rounded-xl shadow-sm relative overflow-hidden">
        <span class="material-symbols-outlined absolute -right-4 -bottom-4 text-9xl opacity-10">factory</span>
        <span class="font-sans text-[10px] font-bold text-[#261900] bg-[#fed488] px-2 py-0.5 rounded uppercase tracking-widest mb-3 inline-block">Industry News</span>
        <h4 class="font-serif text-xl font-bold mb-4">
          Ahmedabad HQ Capacity Expansion: Q4 Roadmap
        </h4>
        <p class="text-[#8393b5] font-sans text-sm">
          Official announcement regarding our new 45,000 sq. ft facility designed for high-end technical fabrics.
        </p>
      </div>
    </div>

    <!-- Small cards row -->
    {smallCards.map((card) => (
      <a href={card.href} class="md:col-span-4 bg-[#f3f4f5] rounded-xl p-6 group block hover:shadow-md transition-shadow">
        <div class="aspect-video mb-6 rounded-lg overflow-hidden bg-slate-200">
          <img
            src={card.img}
            alt={card.alt}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
        <h4 class="font-serif text-lg text-[#041632] font-bold mb-2">{card.title}</h4>
        <p class="text-[#44474d] text-sm font-sans">{card.desc}</p>
      </a>
    ))}

  </div>
</section>
