---
import type { ApiProductLocation } from "../../lib/api";
interface Props { data: ApiProductLocation; }
const { data } = Astro.props;
const { product, location } = data;
---
<section class="py-20 text-center" style="background-color: var(--color-pl-primary); color: var(--color-pl-on-primary)">
  <div class="max-w-2xl mx-auto px-6">
    <h2 class="font-headline text-4xl mb-4">Ready to Source {product.name}?</h2>
    <p class="mb-8 opacity-80 font-body">Connect with our {location.name} team for bulk inquiries, samples, or technical consultations.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/support" class="px-8 py-4 rounded-[0.125rem] font-body font-bold transition-colors" style="background-color: var(--color-pl-tertiary); color: var(--color-pl-on-tertiary)">Request a Quote</a>
      <a href="/fabric" class="px-8 py-4 rounded-[0.125rem] font-body font-bold border border-white/20 transition-colors hover:bg-white/10" style="background-color: rgba(255,255,255,0.1); color: white">Browse All Fabrics</a>
    </div>
  </div>
</section>

