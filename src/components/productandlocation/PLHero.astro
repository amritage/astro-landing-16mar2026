---
import type { ApiProductLocation } from "../../lib/api";
interface Props { data: ApiProductLocation; }
const { data } = Astro.props;

const heroImg = data.image1CloudUrlHero ?? data.image1CloudUrl ?? data.product.image1CloudUrlHero ?? data.product.image1CloudUrl ?? "";
const heroAlt = data.altTextImage1 ?? `${data.product.name} supply in ${data.location.name}`;
const headline = data.title ?? `${data.product.name} Supply in ${data.location.name}`;
const sub = data.tagline ?? `Reliable bulk supply of premium ${data.product.content.join(", ")} ${data.product.structure.toLowerCase()} fabric for global markets. Engineered for durability, finished for luxury.`;

// Use first 3 keywords joined as the eyebrow label, fallback to static text
const eyebrow = data.keywords?.length
  ? data.keywords.slice(0, 3).join(" • ")
  : "Industrial Precision • Legacy Quality";
---

<section class="relative min-h-[560px] md:min-h-[870px] flex items-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    {heroImg && <img src={heroImg} alt={heroAlt} class="w-full h-full object-cover grayscale-[0.3] contrast-[1.1]" loading="eager" fetchpriority="high" />}
    <div class="absolute inset-0 bg-gradient-to-r from-[#001a40]/90 to-[#001a40]/20"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 md:px-8 w-full py-16 md:py-24">
    <div class="max-w-3xl">
      <span class="text-[#ecc15c] font-label text-xs md:text-sm tracking-[0.2em] uppercase mb-3 md:mb-4 block">{eyebrow}</span>
      <h1 class="text-3xl sm:text-5xl md:text-7xl font-headline mb-4 md:mb-6 leading-[1.1] text-white">{headline}</h1>
      <p class="text-[#d7e2ff] text-base md:text-xl mb-8 md:mb-10 max-w-xl font-body leading-relaxed">{sub}</p>
      <div class="flex flex-col sm:flex-row gap-3 md:gap-4">
        <a href="/support" class="bg-[#385b99] hover:bg-[#755700] text-white px-6 md:px-8 py-3 md:py-4 rounded-[0.125rem] font-body font-semibold transition-all duration-300 flex items-center justify-center gap-2 text-sm md:text-base">
          Request Technical Sheet
          <span class="material-symbols-outlined text-sm">download</span>
        </a>
        <a href="/support" class="border border-white/30 backdrop-blur-sm text-white px-6 md:px-8 py-3 md:py-4 rounded-[0.125rem] font-body font-semibold hover:bg-white/10 transition-all flex items-center justify-center text-sm md:text-base">
          Consult with Expert
        </a>
      </div>
    </div>
  </div>
</section>
