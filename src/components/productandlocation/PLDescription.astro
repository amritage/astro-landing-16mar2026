---
import type { ApiProductLocation } from "../../lib/api";

interface Props {
  data: ApiProductLocation;
}
const { data } = Astro.props;

const { fulldescription, product, location } = data;
---

{fulldescription && (
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

        <!-- Rich text -->
        <div class="lg:col-span-8">
          <h2 class="text-3xl md:text-4xl font-headline text-[#041632] mb-8 flex items-center gap-4">
            <span class="w-10 h-px bg-[#775a19]"></span>
            {product.name} in {location.name}
          </h2>
          <div class="rich-content text-slate-600 leading-relaxed font-body" set:html={fulldescription} />
        </div>

        <!-- Side panel -->
        <div class="lg:col-span-4 space-y-6">
          <!-- Collection card -->
          {product.collection?.collectionImage1CloudUrl && (
            <div class="rounded-lg overflow-hidden border border-slate-200 shadow-sm">
              <img
                src={product.collection.collectionImage1CloudUrl}
                alt={product.collection.altTextCollectionImage1 ?? product.collectionName}
                class="w-full aspect-video object-cover"
                loading="lazy"
              />
              <div class="p-4 bg-white">
                <span class="text-[10px] uppercase tracking-widest text-slate-500 font-label">Collection</span>
                <p class="font-headline text-[#041632] text-lg mt-1">{product.collectionName}</p>
                {product.collection.description && (
                  <p class="text-xs text-slate-500 mt-2 font-body leading-relaxed line-clamp-3">{product.collection.description}</p>
                )}
              </div>
            </div>
          )}

          <!-- Keywords -->
          {data.keywords.length > 0 && (
            <div class="p-5 bg-white rounded-lg border border-slate-200">
              <h4 class="text-xs font-bold uppercase tracking-widest text-[#041632] mb-3 font-label">Related Terms</h4>
              <div class="flex flex-wrap gap-2">
                {data.keywords.map((kw) => (
                  <span class="px-2 py-1 bg-slate-100 text-slate-600 text-[10px] font-label rounded">{kw}</span>
                ))}
              </div>
            </div>
          )}
        </div>

      </div>
    </div>
  </section>
)}
