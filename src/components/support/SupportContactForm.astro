---
---
<section class="py-20 md:py-28 px-8 bg-[#f3f4f5]">
  <div class="max-w-2xl mx-auto">
    <div class="text-center mb-10">
      <span class="inline-block px-4 py-1 mb-6 border border-[#775a19] text-[#775a19] font-sans text-xs tracking-[0.2em] uppercase">
        Direct Inquiry
      </span>
      <h2 class="font-serif text-3xl md:text-4xl text-[#041632] mb-3 leading-tight">Send us a Message</h2>
      <p class="text-[#5a6a85] text-sm">Fill out the form below and we'll get back to you shortly.</p>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-8 md:p-12">
      <!-- Stepper -->
      <div class="flex items-center justify-center gap-0 mb-2">
        <div class="h-px w-16 bg-[#d1d5db]"></div>
        <div id="step-dot-1" class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-sans font-semibold bg-[#041632] text-white z-10">1</div>
        <div id="step-line-1" class="h-px w-16 bg-[#d1d5db] transition-colors duration-300"></div>
        <div id="step-dot-2" class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-sans font-semibold border-2 border-[#d1d5db] text-[#9ca3af] z-10 transition-all duration-300">2</div>
        <div id="step-line-2" class="h-px w-16 bg-[#d1d5db] transition-colors duration-300"></div>
        <div id="step-dot-3" class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-sans font-semibold border-2 border-[#d1d5db] text-[#9ca3af] z-10 transition-all duration-300">3</div>
        <div class="h-px w-16 bg-[#d1d5db]"></div>
      </div>
      <p id="step-label" class="text-center font-sans text-xs tracking-widest uppercase text-[#5a6a85] mb-8">Step 1 of 3</p>

      <form id="msf" novalidate>
        <!-- Honeypot -->
        <input type="text" name="_hp" class="hidden" tabindex="-1" autocomplete="off" />

        <!-- STEP 1: Personal Info -->
        <div id="step-1" class="space-y-5">
          <div>
            <label class="field-label">Salutation</label>
            <select name="salutationName" class="field-input">
              <option value="">Select salutation</option>
              <option value="Mr.">Mr.</option>
              <option value="Ms.">Ms.</option>
              <option value="Mrs.">Mrs.</option>
              <option value="Dr.">Dr.</option>
              <option value="Prof.">Prof.</option>
            </select>
          </div>
          <div>
            <label class="field-label">First Name <span class="text-[#775a19]">*</span></label>
            <input type="text" name="firstName" required class="field-input" placeholder="Your first name" />
          </div>
          <div>
            <label class="field-label">Last Name <span class="text-[#775a19]">*</span></label>
            <input type="text" name="lastName" required class="field-input" placeholder="Your last name" />
          </div>
          <div>
            <label class="field-label">Middle Name</label>
            <input type="text" name="middleName" class="field-input" placeholder="Your middle name (optional)" />
          </div>
          <div>
            <label class="field-label">Email Address <span class="text-[#775a19]">*</span></label>
            <input type="email" name="emailAddress" class="field-input" placeholder="your@company.com" />
          </div>
          <div>
            <label class="field-label">Phone Number <span class="text-[#775a19]">*</span></label>
            <input type="tel" name="phoneNumber" class="field-input" placeholder="+91 00000 00000" />
            <p class="text-xs text-[#9ca3af] mt-1">* Please provide either an email address or phone number</p>
          </div>
          <div class="flex justify-end pt-2">
            <button type="button" id="next-1" class="btn-primary">Next Step</button>
          </div>
        </div>

        <!-- STEP 2: Company & Address -->
        <div id="step-2" class="space-y-5 hidden">
          <div>
            <label class="field-label">Company Name</label>
            <input type="text" name="accountName" class="field-input" placeholder="Your company name" />
          </div>
          <div>
            <label class="field-label">Street Address</label>
            <input type="text" name="addressStreet" class="field-input" placeholder="Street address" />
          </div>
          <div>
            <label class="field-label">City</label>
            <input type="text" name="addressCity" class="field-input" placeholder="City" />
          </div>
          <div>
            <label class="field-label">State / Province</label>
            <input type="text" name="addressState" class="field-input" placeholder="State or Province" />
          </div>
          <div>
            <label class="field-label">Country</label>
            <input type="text" name="addressCountry" class="field-input" placeholder="Country" />
          </div>
          <div>
            <label class="field-label">Postal Code</label>
            <input type="text" name="addressPostalCode" class="field-input" placeholder="Postal/ZIP code" />
          </div>
          <div class="flex justify-between pt-2">
            <button type="button" id="prev-2" class="btn-secondary">Previous</button>
            <button type="button" id="next-2" class="btn-primary">Next Step</button>
          </div>
        </div>

        <!-- STEP 3: Business Details -->
        <div id="step-3" class="space-y-5 hidden">
          <div>
            <label class="field-label">Business Type</label>
            <select name="cBusinessType" class="field-input">
              <option value="">Select business type</option>
              <option value="fabric-importer">Fabric Importer</option>
              <option value="fabric-exporter">Fabric Exporter</option>
              <option value="garment-manufacturer">Garment Manufacturer</option>
              <option value="retailer">Retailer</option>
              <option value="wholesaler">Wholesaler</option>
              <option value="buying-agent">Buying Agent</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label class="field-label">Fabric Category</label>
            <select name="cFabricCategory" class="field-input">
              <option value="">Select fabric category</option>
              <option value="cotton">Cotton</option>
              <option value="denim">Denim</option>
              <option value="polyester">Polyester</option>
              <option value="knit">Knit</option>
              <option value="woven">Woven</option>
              <option value="blended">Blended</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label class="field-label">Opportunity Amount</label>
            <div class="flex gap-3">
              <input type="number" name="opportunityAmount" class="field-input flex-1" placeholder="0.00" min="0" step="0.01" />
              <select name="opportunityAmountCurrency" class="field-input w-28">
                <option value="USD">USD</option>
                <option value="INR">INR</option>
                <option value="EUR">EUR</option>
                <option value="GBP">GBP</option>
              </select>
            </div>
          </div>
          <div>
            <label class="field-label">Description</label>
            <textarea name="description" rows="4" class="field-input resize-none" placeholder="Please describe your requirements, specifications, or any additional information"></textarea>
          </div>

          <div id="form-success" class="hidden px-4 py-3 bg-green-50 border border-green-200 text-green-800 text-sm rounded">
            Thank you! Your inquiry has been received. We'll be in touch shortly.
          </div>
          <div id="form-error" class="hidden px-4 py-3 bg-red-50 border border-red-200 text-red-800 text-sm rounded">
            Something went wrong. Please try again or email us directly.
          </div>

          <div class="flex justify-between pt-2">
            <button type="button" id="prev-3" class="btn-secondary">Previous</button>
            <button type="submit" id="form-submit" class="btn-primary">Submit Request</button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  .field-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #041632;
    margin-bottom: 0.5rem;
  }
  .field-input {
    width: 100%;
    border: 1px solid #d1d5db;
    border-radius: 0.25rem;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: #041632;
    background: white;
    outline: none;
    transition: border-color 0.2s;
  }
  .field-input:focus {
    border-color: #041632;
  }
  .btn-primary {
    background: #041632;
    color: white;
    padding: 0.75rem 2rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-primary:hover {
    background: #775a19;
  }
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .btn-secondary {
    background: white;
    color: #041632;
    padding: 0.75rem 2rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid #d1d5db;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .btn-secondary:hover {
    border-color: #041632;
  }
</style>

<script>
  const ESPO_URL = 'https://espo.egport.com/api/v1/LeadCapture/a4624c9bb58b8b755e3d94f1a25fc9be';

  const form = document.getElementById('msf') as HTMLFormElement;
  const steps = [
    document.getElementById('step-1')!,
    document.getElementById('step-2')!,
    document.getElementById('step-3')!,
  ];
  const dots = [
    document.getElementById('step-dot-1')!,
    document.getElementById('step-dot-2')!,
    document.getElementById('step-dot-3')!,
  ];
  const lines = [
    document.getElementById('step-line-1')!,
    document.getElementById('step-line-2')!,
  ];
  const stepLabel = document.getElementById('step-label')!;
  let current = 0;

  function goTo(n: number) {
    steps[current].classList.add('hidden');
    current = n;
    steps[current].classList.remove('hidden');
    stepLabel.textContent = `Step ${current + 1} of 3`;

    dots.forEach((dot, i) => {
      if (i <= current) {
        dot.classList.remove('border-2', 'border-[#d1d5db]', 'text-[#9ca3af]');
        dot.classList.add('bg-[#041632]', 'text-white');
      } else {
        dot.classList.add('border-2', 'border-[#d1d5db]', 'text-[#9ca3af]');
        dot.classList.remove('bg-[#041632]', 'text-white');
      }
    });
    lines.forEach((line, i) => {
      line.classList.toggle('bg-[#041632]', i < current);
      line.classList.toggle('bg-[#d1d5db]', i >= current);
    });
  }

  function validateStep1(): boolean {
    const firstName = (form.querySelector('[name="firstName"]') as HTMLInputElement).value.trim();
    const lastName = (form.querySelector('[name="lastName"]') as HTMLInputElement).value.trim();
    const email = (form.querySelector('[name="emailAddress"]') as HTMLInputElement).value.trim();
    const phone = (form.querySelector('[name="phoneNumber"]') as HTMLInputElement).value.trim();
    if (!firstName || !lastName) { alert('Please enter your first and last name.'); return false; }
    if (!email && !phone) { alert('Please provide at least an email or phone number.'); return false; }
    return true;
  }

  document.getElementById('next-1')!.addEventListener('click', () => { if (validateStep1()) goTo(1); });
  document.getElementById('prev-2')!.addEventListener('click', () => goTo(0));
  document.getElementById('next-2')!.addEventListener('click', () => goTo(2));
  document.getElementById('prev-3')!.addEventListener('click', () => goTo(1));

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const hp = (form.querySelector('[name="_hp"]') as HTMLInputElement).value;
    if (hp) return;

    const submitBtn = document.getElementById('form-submit') as HTMLButtonElement;
    const successMsg = document.getElementById('form-success')!;
    const errorMsg = document.getElementById('form-error')!;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    const g = (name: string) => (form.querySelector(`[name="${name}"]`) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement)?.value ?? '';

    const businessType = g('cBusinessType');
    const fabricCategory = g('cFabricCategory');
    const amount = g('opportunityAmount');

    const payload: Record<string, unknown> = {
      salutationName: g('salutationName'),
      firstName: g('firstName'),
      lastName: g('lastName'),
      middleName: g('middleName'),
      emailAddress: g('emailAddress'),
      phoneNumber: g('phoneNumber'),
      accountName: g('accountName'),
      addressStreet: g('addressStreet'),
      addressCity: g('addressCity'),
      addressState: g('addressState'),
      addressCountry: g('addressCountry'),
      addressPostalCode: g('addressPostalCode'),
      cBusinessType: businessType ? [businessType] : [],
      cFabricCategory: fabricCategory ? [fabricCategory] : [],
      opportunityAmount: amount ? parseFloat(amount) : null,
      opportunityAmountCurrency: g('opportunityAmountCurrency') || 'USD',
      description: g('description'),
    };

    try {
      const res = await fetch(ESPO_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        form.reset();
        goTo(0);
        successMsg.classList.remove('hidden');
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Request';
    }
  });
</script>
