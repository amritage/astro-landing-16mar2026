---
---
<section class="py-24 bg-[#f3f4f5]" id="apply-now">
  <div class="max-w-2xl mx-auto px-8">
    <div class="text-center mb-12">
      <span class="material-symbols-outlined text-4xl text-[#775a19] mb-4 block" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;">work</span>
      <span class="font-sans text-xs uppercase tracking-[0.3em] text-[#ffdea5] bg-[#041632] px-4 py-1 inline-block mb-6">
        Join the Team
      </span>
      <h2 class="font-serif text-5xl text-[#041632] italic mb-4">Apply Now</h2>
      <p class="text-[#44474d] text-sm">Begin your journey with Amrita Global.</p>
    </div>

    <div class="bg-white border border-[#e1e3e4] p-10">
      <!-- Progress indicator -->
      <div class="flex items-center mb-10">
        <div class="flex flex-col items-center gap-1">
          <div class="w-8 h-8 rounded-full border-2 border-[#775a19] flex items-center justify-center text-xs font-bold text-[#775a19]">1</div>
          <span class="text-[10px] uppercase font-bold text-[#775a19] tracking-widest">Personal</span>
        </div>
        <div class="h-px flex-1 bg-[#e1e3e4] mx-3"></div>
        <div class="flex flex-col items-center gap-1">
          <div class="w-8 h-8 rounded-full border-2 border-[#c5c6ce] flex items-center justify-center text-xs font-bold text-[#75777e]">2</div>
          <span class="text-[10px] uppercase font-bold text-[#75777e] tracking-widest">Experience</span>
        </div>
        <div class="h-px flex-1 bg-[#e1e3e4] mx-3"></div>
        <div class="flex flex-col items-center gap-1">
          <div class="w-8 h-8 rounded-full border-2 border-[#c5c6ce] flex items-center justify-center text-xs font-bold text-[#75777e]">3</div>
          <span class="text-[10px] uppercase font-bold text-[#75777e] tracking-widest">Resume</span>
        </div>
      </div>

      <form action="#" class="space-y-6">
        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-[#041632] mb-2">Full Name</label>
          <input
            type="text"
            placeholder="Enter your full name"
            class="w-full bg-[#f3f4f5] border border-[#c5c6ce] px-4 py-3 text-sm focus:outline-none focus:border-[#775a19] focus:ring-1 focus:ring-[#775a19] transition-colors"
          />
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-[#041632] mb-2">Email Address</label>
          <input
            type="email"
            placeholder="email@example.com"
            class="w-full bg-[#f3f4f5] border border-[#c5c6ce] px-4 py-3 text-sm focus:outline-none focus:border-[#775a19] focus:ring-1 focus:ring-[#775a19] transition-colors"
          />
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-[#041632] mb-2">Phone Number</label>
          <input
            type="tel"
            placeholder="+91 XXXXX XXXXX"
            class="w-full bg-[#f3f4f5] border border-[#c5c6ce] px-4 py-3 text-sm focus:outline-none focus:border-[#775a19] focus:ring-1 focus:ring-[#775a19] transition-colors"
          />
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-[#041632] mb-2">Position Applied For</label>
          <select class="w-full bg-[#f3f4f5] border border-[#c5c6ce] px-4 py-3 text-sm focus:outline-none focus:border-[#775a19] focus:ring-1 focus:ring-[#775a19] transition-colors">
            <option value="">Select a position</option>
            <option>Production Manager</option>
            <option>B2B Strategy Lead</option>
            <option>Logistics Manager</option>
            <option>Other</option>
          </select>
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-[#041632] mb-2">Total Years of Experience</label>
          <input
            type="number"
            placeholder="e.g. 5"
            min="0"
            class="w-full bg-[#f3f4f5] border border-[#c5c6ce] px-4 py-3 text-sm focus:outline-none focus:border-[#775a19] focus:ring-1 focus:ring-[#775a19] transition-colors"
          />
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-[#041632] mb-2">Cover Letter</label>
          <textarea
            rows="4"
            placeholder="Briefly describe why you are a good fit"
            class="w-full bg-[#f3f4f5] border border-[#c5c6ce] px-4 py-3 text-sm focus:outline-none focus:border-[#775a19] focus:ring-1 focus:ring-[#775a19] transition-colors resize-none"
          ></textarea>
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-[#041632] mb-2">Upload Resume (PDF/DOCX)</label>
          <label class="flex flex-col items-center justify-center border-2 border-dashed border-[#c5c6ce] px-6 py-8 cursor-pointer hover:border-[#775a19] transition-colors group">
            <span class="material-symbols-outlined text-[#75777e] text-3xl mb-2 group-hover:text-[#775a19] transition-colors">upload_file</span>
            <span class="text-sm text-[#44474d]">
              <span class="font-bold text-[#775a19]">Upload a file</span> or drag and drop
            </span>
            <span class="text-xs text-[#75777e] mt-1">PDF or DOCX · Up to 10MB</span>
            <input type="file" accept=".pdf,.docx" class="sr-only" />
          </label>
        </div>

        <button
          type="submit"
          class="w-full bg-[#041632] text-white py-4 font-sans font-bold tracking-widest uppercase text-sm hover:bg-[#775a19] transition-colors"
        >
          Submit Application
        </button>
      </form>
    </div>
  </div>
</section>
