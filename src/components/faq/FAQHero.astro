---
---
<section class="relative bg-[#041632] py-16 md:py-24 overflow-hidden">
  <div class="pointer-events-none absolute inset-0 opacity-10">
    <div class="absolute -left-1/4 top-0 w-full h-full -rotate-45 bg-gradient-to-r from-[#775a19] to-transparent blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 md:px-8 text-center">
    <span class="font-label uppercase tracking-widest text-[#ffdea5] text-xs mb-4 block">
      Knowledge Base
    </span>
    <h1 class="font-headline text-4xl md:text-7xl text-white mb-8 italic leading-tight">
      Expert Answers for Fabric Buyers
    </h1>

    <div class="relative max-w-2xl mx-auto">
      <div class="absolute inset-y-0 left-4 md:left-6 flex items-center pointer-events-none">
        <span class="material-symbols-outlined text-[#ffdea5]">search</span>
      </div>
      <input
        id="faq-search"
        type="text"
        placeholder="Search questions..."
        class="w-full pl-12 md:pl-16 pr-4 md:pr-40 py-4 md:py-5 bg-white/10 border border-white/20 text-white placeholder:text-[#8393b5] focus:ring-1 focus:ring-[#775a19] outline-none transition-all text-base md:text-lg"
      />
      <button class="mt-3 w-full md:mt-0 md:absolute md:inset-y-2 md:right-2 md:w-auto px-8 py-3 bg-[#775a19] text-white font-bold hover:bg-[#fed488] hover:text-[#041632] transition-all uppercase text-sm tracking-widest">
        Search
      </button>
    </div>
  </div>
</section>
