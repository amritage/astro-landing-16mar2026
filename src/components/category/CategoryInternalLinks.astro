---
import type { ApiTopicPage } from "../../lib/api";

interface Props {
  currentSlug: string;
  categories: ApiTopicPage[];
}
const { currentSlug, categories } = Astro.props;

const others = categories.filter((c) => c.slug !== currentSlug);
---

{others.length > 0 && (
  <section class="py-12 border-t border-[#c3c6d1]/30">
    <div class="max-w-7xl mx-auto px-6">
      <h5 class="font-label text-[10px] uppercase tracking-widest text-[#747781] mb-6">
        Explore More Categories
      </h5>
      <div class="flex flex-wrap gap-x-8 gap-y-4">
        {others.map((cat) => (
          <a
            href={`/category/${cat.slug}`}
            class="text-sm font-medium text-[#1a1b20] hover:text-[#755700] underline decoration-[#385b99]/20 hover:decoration-[#755700] underline-offset-4 transition-colors"
          >
            {cat.name}
          </a>
        ))}
        <a
          href="/fabric"
          class="text-sm font-medium text-[#1a1b20] hover:text-[#755700] underline decoration-[#385b99]/20 hover:decoration-[#755700] underline-offset-4 transition-colors"
        >
          Full Fabric Library
        </a>
      </div>
    </div>
  </section>
)}
