---
import type { ApiCompanyInfo, ApiProductLocation } from "../../lib/api";
import type { FabricManufacturerLandingPreview } from "../../data/fabricManufacturerLandingPreview";

interface Props {
  company: ApiCompanyInfo | null;
  data: ApiProductLocation;
  landing: FabricManufacturerLandingPreview;
  phone1: string | null;
  phone2: string | null;
  email: string | null;
}

const { company, data, landing, phone1, phone2, email } = Astro.props;
const logoSrc = company?.logoUrl ?? "/images/icons/my_logo.webp";

function firstSentence(value: string | null | undefined): string | null {
  if (!value) return null;
  const cleaned = value.replace(/\s+/g, " ").trim();
  if (!cleaned) return null;
  const match = cleaned.match(/.*?[.!?](?:\s|$)/);
  return (match?.[0] ?? cleaned).trim();
}

const footerEyebrow =
  data.location.locationTagline?.trim() ||
  `${data.location.name} B2B Fabric Supply`;
const footerPrimaryLine =
  firstSentence(data.location.description) ||
  data.productlocationA3?.trim() ||
  data.tagline?.trim() ||
  `${data.location.name} fabric sourcing support for business buyers.`;
const footerBody = [footerPrimaryLine, landing.responsePromise].join(" ");
---

<footer class="bg-[#041632] pb-28 pt-10 text-white md:pb-10">
  <div class="mx-auto flex max-w-7xl flex-col gap-8 px-4 md:flex-row md:items-end md:justify-between md:px-8">
    <div class="max-w-xl">
      <div class="flex items-center gap-3">
        <img src={logoSrc} alt={`${company?.legalName ?? "Amrita Global Enterprises"} logo`} width="42" height="42" class="h-10 w-10 object-contain" />
        <div>
          <p class="text-lg font-extrabold">{company?.legalName ?? "Amrita Global Enterprises"}</p>
          <p class="text-xs uppercase tracking-[0.18em] text-white/60">{footerEyebrow}</p>
        </div>
      </div>
      <p class="mt-4 text-sm leading-relaxed text-white/72">
        {footerBody}
      </p>
    </div>

    <div class="grid gap-3 text-sm">
      {email && (
        <a href={`mailto:${email}`} class="rounded-full border border-white/14 bg-white/8 px-4 py-2 text-white no-underline transition-colors hover:bg-white/14">
          {email}
        </a>
      )}
      {phone1 && (
        <a href={`tel:${phone1.replace(/[^\d+]/g, "")}`} class="rounded-full border border-white/14 bg-white/8 px-4 py-2 text-white no-underline transition-colors hover:bg-white/14">
          {phone1}
        </a>
      )}
      {phone2 && (
        <a href={`tel:${phone2.replace(/[^\d+]/g, "")}`} class="rounded-full border border-white/14 bg-white/8 px-4 py-2 text-white no-underline transition-colors hover:bg-white/14">
          {phone2}
        </a>
      )}
    </div>
  </div>
</footer>
