---
import type { ApiProductLocation } from "../../lib/api";

interface Props {
  data: ApiProductLocation;
  applications: string[];
}

const { applications } = Astro.props;

function pickKeyword(keywords: string[], pattern: RegExp, fallback: string): string {
  return keywords.find((keyword) => pattern.test(keyword)) ?? keywords[0] ?? fallback;
}

function formatList(values: string[]): string {
  if (values.length <= 1) return values[0] ?? "";
  if (values.length === 2) return `${values[0]} and ${values[1]}`;
  return `${values.slice(0, -1).join(", ")}, and ${values.at(-1)}`;
}

const sectionEyebrow = pickKeyword(
  Astro.props.data.keywords ?? [],
  /(garment fabric supplier|woven fabric supplier|b2b fabric supplier)/i,
  `Suitable for ${Astro.props.data.location.name} buyers`,
);

const sectionHeading = `${Astro.props.data.product.name} application fit for Ahmedabad garment buyers`;

const sectionBody = [
  Astro.props.data.productlocationA3?.trim(),
  applications.length > 0
    ? `Common buyer requests include ${formatList(applications)}.`
    : null,
]
  .filter((value): value is string => Boolean(value))
  .join(" ");

const normalizedFinishes = [...new Set(
  (Astro.props.data.product.finish ?? [])
    .map((finish) => finish.replace(/^.*?-\s*/, "").trim())
    .filter(Boolean),
)];

const buyerNote = normalizedFinishes.length > 0
  ? `Confirm ${formatList(normalizedFinishes).toLowerCase()} finish suitability, sample requirement, and repeat-order availability for your end use.`
  : "Confirm sample requirement and repeat-order availability for your end use.";
---

<section class="bg-[#f8fafc] py-12 md:py-20">
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)]">
      <div>
        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#755700]">{sectionEyebrow}</p>
        <h2 class="mt-3 text-3xl font-headline text-[#041632] md:text-4xl">{sectionHeading}</h2>
        <p class="mt-4 text-base leading-relaxed text-[#5a6a85]">{sectionBody}</p>
        <div class="mt-5 rounded-[24px] border border-[#dde3ec] bg-white p-5">
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#385b99]">Buyer note</p>
          <p class="mt-2 text-sm leading-relaxed text-[#5a6a85]">{buyerNote}</p>
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
        {applications.map((application) => (
          <div class="rounded-[24px] border border-[#dde3ec] bg-white px-5 py-4 shadow-[0_12px_28px_rgba(4,22,50,0.05)]">
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined mt-0.5 text-[#385b99]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
              <p class="text-base font-semibold text-[#041632]">{application}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
