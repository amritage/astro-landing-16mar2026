---
interface Props {
  metrics: Array<{ stat: string; label: string }>;
}

const { metrics } = Astro.props;
---

<section class="bg-[#f4f3f9] py-8 md:py-10">
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <div class="grid gap-3 md:grid-cols-4">
      {metrics.map((metric) => (
        <div class="rounded-[24px] border border-[#dce1ea] bg-white px-5 py-6 text-center shadow-[0_14px_32px_rgba(4,22,50,0.05)]">
          <p class="text-4xl font-headline text-[#385b99]">{metric.stat}</p>
          <p class="mt-2 text-[11px] font-bold uppercase tracking-[0.18em] text-[#5a6a85]">{metric.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
