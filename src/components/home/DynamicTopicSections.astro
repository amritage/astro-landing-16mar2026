---
import { getDynamicTopicPages, getProductsByMerchTag } from "../../lib/api";
import { mapApiProduct } from "../../data/products";

const topics = await getDynamicTopicPages();

const sections = await Promise.all(
  topics.map(async (topic) => {
    const raw = await getProductsByMerchTag(topic.slug1, 4);
    const products = raw
      .filter((p) => (p.productslug ?? "").trim().toLowerCase() !== "pending")
      .map(mapApiProduct);
    return { topic, products };
  })
);
---

{sections.map(({ topic, products }, index) => (
  <div class="section-wrapper">
  <section class:list={["topic-section", index % 2 === 0 ? "topic-section--light" : "topic-section--white"]}>
    <div class="container mx-auto px-4 md:px-8">
      <div class="mb-12 md:mb-16">
        <a href={`/collection/${topic.slug}`} class="group inline-block">
          <h2 class="font-headline text-4xl md:text-5xl text-[#041632] mb-3 md:mb-4 group-hover:text-[#775a19] transition-colors">{topic.name}</h2>
        </a>
        {topic.description && (
          <p class="font-label text-xs md:text-sm uppercase tracking-[0.3em] md:tracking-[0.4em] text-[#775a19]">{topic.description}</p>
        )}
      </div>

      {products.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
          {products.map((product) => (
            <a href={`/collection/${topic.slug}/${product.slug}`} class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-[#edeeef] block">
              <div class="aspect-square bg-[#f3f4f5] overflow-hidden">
                <img
                  class="w-full h-full object-cover"
                  src={product.image || "/images/placeholders/fabric.jpg"}
                  alt={product.imageAlt || product.name}
                  title={product.imageAlt || product.name}
                  width="300"
                  height="300"
                  loading="lazy"
                />
              </div>
              <div class="p-4 md:p-6">
                <span class="font-label text-[9px] md:text-[10px] text-[#775a19] font-bold uppercase tracking-widest">{product.seriesLabel}</span>
                <h3 class="font-headline text-lg md:text-xl text-[#041632] mt-1 mb-2">{product.name}</h3>
                <div class="flex justify-between items-center pt-3 md:pt-4 border-t border-[#edeeef]">
                  <span class="font-body text-[10px] md:text-xs text-[#44474d] italic">{product.specs.weight} | {product.specs.weave}</span>
                  <span class="text-[#041632] font-label text-[10px] font-bold uppercase tracking-widest hover:text-[#775a19]">Details</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-center text-[#44474d] font-body text-sm">No products found for this collection.</p>
      )}

      <div class="flex justify-center mt-10 md:mt-14">
        <a
          href={`/collection/${topic.slug}`}
          class="font-label text-xs md:text-sm font-bold text-[#775a19] uppercase tracking-widest flex items-center gap-2 border-b-2 border-[#775a19] pb-1"
        >
          Explore Full Library
        </a>
      </div>
    </div>
    </section>
  </div>
))}

<style>
  .section-wrapper {
    position: relative;
  }

  .topic-section {
    padding: 4rem 0;
    position: relative;
  }

  .topic-section--light {
    background: #f8f9fa;
    box-shadow: inset 0 8px 24px rgba(4, 22, 50, 0.04), inset 0 -8px 24px rgba(4, 22, 50, 0.04);
  }

  .topic-section--white {
    background: #ffffff;
    box-shadow: inset 0 8px 24px rgba(119, 90, 25, 0.04), inset 0 -8px 24px rgba(119, 90, 25, 0.04);
  }

  @media (min-width: 768px) {
    .topic-section {
      padding: 6rem 0;
    }
  }
</style>
