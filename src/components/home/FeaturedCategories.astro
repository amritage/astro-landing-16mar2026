---
import { getCategoryTopicPages } from "../../lib/api";
import CloudinaryImage from "../common/CloudinaryImage.astro";

interface Props {}

const categories = await getCategoryTopicPages();
---

{categories.length > 0 && (
  <section class="py-16 md:py-24 bg-[#f8f9fa]">
    <div class="container mx-auto px-4 md:px-8">

      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-16 gap-6">
        <div class="max-w-2xl">
          <h2 class="font-headline text-4xl md:text-5xl text-[#041632] mb-4">The Material Core</h2>
          <p class="font-body text-base md:text-lg text-[#44474d]">Our signature fabrics are engineered for durability, hand-feel, and consistent quality.</p>
        </div>
        <a
          class="font-label text-xs md:text-sm font-bold text-[#775a19] uppercase tracking-widest flex items-center gap-2 border-b-2 border-[#775a19] pb-1"
          href="/fabric"
        >
          Explore Full Library
        </a>
      </div>

      <!-- Carousel wrapper: scrolls on mobile, grid on desktop -->
      <div class="fc-outer">
        <div class="fc-track" id="fc-track">
          {categories.map((cat) => (
            <a href={`/category/${cat.slug}`} class="fc-card group">
              <div class="aspect-[3/4] overflow-hidden rounded-xl relative">
                {cat.image1CloudUrlCard || cat.image1CloudUrl ? (
                  <CloudinaryImage
                    src={cat.image1CloudUrlCard ?? cat.image1CloudUrl}
                    alt={cat.name}
                    title={cat.name}
                    width={480}
                    height={640}
                    widths={[240, 480, 720]}
                    sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 82vw"
                    crop="fill"
                    loading="lazy"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  />
                ) : (
                  <div class="w-full h-full bg-[#d1d5db]" />
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-[#041632]/80 to-transparent flex items-end p-6 md:p-8">
                  <h3 class="!text-white font-headline text-2xl md:text-3xl">{cat.name}</h3>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Arrows (tablet+) -->
        <button class="fc-arrow fc-prev" aria-label="Previous" id="fc-prev">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="fc-arrow fc-next" aria-label="Next" id="fc-next">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

    </div>
  </section>
)}

<style>
  /* ── Outer: never clips on mobile so peek is visible ── */
  .fc-outer {
    position: relative;
  }
  @media (min-width: 1024px) {
    .fc-outer { margin: 0 3rem; }
  }

  /* ── Track ── */
  .fc-track {
    display: flex;
    gap: 1rem;
    /* mobile: horizontal scroll */
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-behavior: smooth;
  }
  .fc-track::-webkit-scrollbar { display: none; }

  @media (min-width: 640px) { .fc-track { gap: 1.25rem; } }
  @media (min-width: 1024px) {
    .fc-track { gap: 1.5rem; }
  }

  /* ── Cards ── */
  .fc-card {
    flex-shrink: 0;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    /* mobile: 82% → next card peeks ~18% */
    width: 82vw;
    box-sizing: border-box;
    display: block;
  }
  @media (min-width: 640px) {
    .fc-card { width: calc(50% - 0.625rem); }
  }
  @media (min-width: 1024px) {
    .fc-card { width: calc(33.333% - 1rem); }
  }

  /* ── Arrows: always hidden by default, JS shows them only when needed ── */
  .fc-arrow {
    display: none;
    position: absolute;
    top: 45%;
    transform: translateY(-50%);
    z-index: 10;
    width: 2.5rem; height: 2.5rem;
    border-radius: 50%;
    background: #020d1f;
    border: none;
    box-shadow: 0 4px 16px rgba(2,13,31,.45);
    align-items: center; justify-content: center;
    cursor: pointer; color: #fff;
    transition: background .18s, box-shadow .18s;
    padding: 0;
  }
  .fc-prev { left: -3rem; }
  .fc-next { right: -3rem; }
  .fc-arrow:hover { background: #775a19; box-shadow: 0 6px 20px rgba(119,90,25,.4); }
  .fc-arrow svg { display: block; flex-shrink: 0; }


</style>

<script>
  const track = document.getElementById("fc-track") as HTMLElement | null;
  const prev  = document.getElementById("fc-prev")  as HTMLButtonElement | null;
  const next  = document.getElementById("fc-next")  as HTMLButtonElement | null;
  if (!track) throw new Error("fc-track missing");

  const cards = () => track.querySelectorAll<HTMLElement>(".fc-card");

  // ── Smart mode: carousel only when cards overflow visible columns ─────────
  function applyMode() {
    const w     = window.innerWidth;
    const cols  = w >= 1024 ? 3 : w >= 640 ? 2 : 1;
    const count = cards().length;
    const needsCarousel = count > cols;

    if (w >= 640) {
      // tablet / desktop: show arrows only when overflow
      if (prev) prev.style.display = needsCarousel ? "flex" : "none";
      if (next) next.style.display = needsCarousel ? "flex" : "none";
    } else {
      // mobile: always scroll (arrows hidden, swipe handles it)
      if (prev) prev.style.display = "none";
      if (next) next.style.display = "none";
    }

    if (w >= 1024) {
      // desktop: carousel scroll when overflow, wrap like grid when not
      track.style.overflowX = needsCarousel ? "hidden" : "visible";
      track.style.flexWrap  = needsCarousel ? "nowrap"  : "wrap";
    } else {
      track.style.overflowX = "";
      track.style.flexWrap  = "nowrap";
    }
  }

  applyMode();
  window.addEventListener("resize", applyMode);

  // ── Arrow scroll ──────────────────────────────────────────────────────────
  const step = () => {
    const card = track.querySelector<HTMLElement>(".fc-card");
    return card ? card.offsetWidth + parseFloat(getComputedStyle(track).gap || "0") : 0;
  };
  prev?.addEventListener("click", () => track.scrollBy({ left: -step(), behavior: "smooth" }));
  next?.addEventListener("click", () => track.scrollBy({ left:  step(), behavior: "smooth" }));

  // ── Touch snap: one card at a time ───────────────────────────────────────
  let tx = 0, ts = 0;
  track.addEventListener("touchstart", (e) => { tx = e.touches[0].clientX; ts = track.scrollLeft; }, { passive: true });
  track.addEventListener("touchend", (e) => {
    const dx   = tx - e.changedTouches[0].clientX;
    const card = track.querySelector<HTMLElement>(".fc-card");
    if (!card) return;
    const s    = card.offsetWidth + parseFloat(getComputedStyle(track).gap || "0");
    const base = Math.round(ts / s);
    const to   = Math.abs(dx) < s * 0.15 ? base : base + (dx > 0 ? 1 : -1);
    track.scrollTo({ left: Math.max(0, to * s), behavior: "smooth" });
  }, { passive: true });
</script>
